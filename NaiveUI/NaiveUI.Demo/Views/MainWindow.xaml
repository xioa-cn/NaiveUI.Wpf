<Window
    x:Class="NaiveUI.Demo.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
    xmlns:viewModels="clr-namespace:NaiveUI.Demo.ViewModels"
    xmlns:views="clr-namespace:NaiveUI.Demo.Views.Shell"
    Title="Naive UI"
    Width="1600"
    Height="920"
    MinWidth="1280"
    MinHeight="760"
    Background="{DynamicResource Theme.Surface.0.Brush}"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    mc:Ignorable="d">
    <Window.DataContext>
        <viewModels:DemoShellViewModel />
    </Window.DataContext>
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="20"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="8"
            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <AdornerDecorator>
        <Border Background="{DynamicResource Theme.Surface.0.Brush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="100" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <views:TopNavBar
                    x:Name="TopNavBar"
                    Grid.Row="0"
                    CloseRequested="HandleCloseRequested"
                    ComponentsRequested="HandleComponentsRequested"
                    DragRequested="HandleDragRequested"
                    HomeRequested="HandleHomeRequested"
                    IsComponentsSelected="{Binding IsComponentsSelected}"
                    IsHomeSelected="{Binding IsHomeSelected}"
                    MaximizeGlyph="{Binding MaximizeGlyph}"
                    MaximizeRestoreRequested="HandleMaximizeRestoreRequested"
                    MinimizeRequested="HandleMinimizeRequested"
                    ThemeToggleRequested="HandleThemeToggleRequested"
                    ThemeToggleText="{Binding ThemeToggleText}"
                    VersionText="{Binding VersionText}" />

                <ContentControl Grid.Row="1" Content="{Binding CurrentPageView}" />
            </Grid>
        </Border>
    </AdornerDecorator>
</Window>

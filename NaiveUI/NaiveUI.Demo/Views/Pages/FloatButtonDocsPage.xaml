<UserControl
    x:Class="NaiveUI.Demo.Views.Pages.FloatButtonDocsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:nc="clr-namespace:NaiveUI.NControls.Controls;assembly=NaiveUI.NControls"
    xmlns:nu="clr-namespace:NaiveUI.NControls.ControlsExample;assembly=NaiveUI.NControls"
    xmlns:sections="clr-namespace:NaiveUI.Demo.Views.Sections"
    xmlns:showMeTheXaml="clr-namespace:ShowMeTheXAML;assembly=ShowMeTheXAML"
    xmlns:viewModels="clr-namespace:NaiveUI.Demo.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewModels:FloatButtonDocsPageViewModel}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="SectionCardHeaderTitleStyle"
            BasedOn="{StaticResource DocSectionTitleStyle}"
            TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
        </Style>

        <Style x:Key="DemoStageStyle" TargetType="Border">
            <Setter Property="Height" Value="220" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Background" Value="{DynamicResource Theme.Surface.1.Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border.Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>



        <Style x:Key="FloatButtonBadgeHostStyle" TargetType="Grid">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Margin" Value="0,0,16,0" />
        </Style>

        <Style x:Key="FloatButtonBadgeStyle" TargetType="Border">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="MinWidth" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="Margin" Value="0,-4,-4,0" />
            <Setter Property="Padding" Value="4,0" />
            <Setter Property="Background" Value="{DynamicResource Primary.First.Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Surface.0.Brush}" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="IsHitTestVisible" Value="False" />
        </Style>

        <Style x:Key="FloatButtonBadgeTextStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Inverse.Brush}" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style
            x:Key="FloatButtonBadgeDotStyle"
            BasedOn="{StaticResource FloatButtonBadgeStyle}"
            TargetType="Border">
            <Setter Property="Width" Value="10" />
            <Setter Property="MinWidth" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Margin" Value="0,-1,-1,0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="5" />
        </Style>

        <Geometry x:Key="FloatButtonCashGeometry">F1 M4.5,7.5 L19.5,7.5 19.5,16.5 4.5,16.5 Z M12,9.75 C9.92893,9.75 8.25,10.7574 8.25,12 C8.25,13.2426 9.92893,14.25 12,14.25 C14.0711,14.25 15.75,13.2426 15.75,12 C15.75,10.7574 14.0711,9.75 12,9.75 Z M6.25,9.5 L7.75,9.5 M16.25,9.5 L17.75,9.5 M6.25,14.5 L7.75,14.5 M16.25,14.5 L17.75,14.5</Geometry>
        <Geometry x:Key="FloatButtonDocumentGeometry">F1 M7.5,3.5 L14.5,3.5 18.5,7.5 18.5,20.5 7.5,20.5 Z M14.5,3.5 L14.5,7.5 18.5,7.5 M10,11 L16,11 M10,14 L16,14 M10,17 L14,17</Geometry>
        <Geometry x:Key="FloatButtonBellGeometry">F1 M12,4.5 C9.51472,4.5 7.5,6.51472 7.5,9 V10.25 C7.5,11.8855 6.85681,13.4556 5.70711,14.7071 L5,15.5 H19 L18.2929,14.7071 C17.1432,13.4556 16.5,11.8855 16.5,10.25 V9 C16.5,6.51472 14.4853,4.5 12,4.5 Z M10,17.5 C10.3094,18.6641 11.2652,19.5 12.5,19.5 C13.7348,19.5 14.6906,18.6641 15,17.5</Geometry>
    </UserControl.Resources>

    <Grid Background="{DynamicResource Theme.Surface.0.Brush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="25,34,18,34">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        FontSize="48"
                        FontWeight="Bold"
                        Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                        Text="浮动按钮 Float Button" />
                </StackPanel>

                <TextBlock
                    Margin="0,26,0,0"
                    FontSize="18"
                    Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                    Text="跟 Back Top 很像，多一份颜值，多一份互动。" />

                <TextBlock
                    Margin="0,52,0,28"
                    FontSize="36"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                    Text="演示" />

                <StackPanel>
                    <nu:CardElement x:Name="SectionBasic" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="基础用法" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <showMeTheXaml:XamlDisplay Style="{StaticResource AvalonEditXamlDisplay}" UniqueKey="FloatButtonDocsPage1">
                                <Border Margin="30,24,30,24" Style="{StaticResource DemoStageStyle}">
                                    <Grid>
                                        <nc:NFloatButton
                                            Bottom="0"
                                            Position="Absolute"
                                            Right="0"
                                            Shape="Square">
                                            <nc:NIcon Data="{StaticResource Starting}" Size="15" />
                                        </nc:NFloatButton>
                                        <nc:NFloatButton
                                            Bottom="0"
                                            Left="0"
                                            Position="Absolute"
                                            Shape="Square"
                                            Type="Primary">
                                            <nc:NIcon Data="{StaticResource Starting}" Size="15" />
                                        </nc:NFloatButton>
                                        <nc:NFloatButton
                                            Position="Absolute"
                                            Right="0"
                                            Top="0">
                                            <nc:NIcon Data="{StaticResource Starting}" Size="15" />
                                        </nc:NFloatButton>
                                        <nc:NFloatButton
                                            Left="0"
                                            Position="Absolute"
                                            Top="0"
                                            Type="Primary">
                                            <nc:NIcon Data="{StaticResource Starting}" Size="15" />
                                        </nc:NFloatButton>
                                    </Grid>
                                </Border>
                            </showMeTheXaml:XamlDisplay>
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionBadge" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="徽章" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <showMeTheXaml:XamlDisplay Style="{StaticResource AvalonEditXamlDisplay}" UniqueKey="FloatButtonDocsPage2">
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,18"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="官方示例里这里搭配了 Badge。WPF 版先用内容组合把同样的视觉关系还原出来。" />
                                    <WrapPanel>
                                        <Grid Style="{StaticResource FloatButtonBadgeHostStyle}">
                                            <nc:NFloatButton Position="Relative">
                                                <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                            </nc:NFloatButton>
                                            <Border Style="{StaticResource FloatButtonBadgeStyle}">
                                                <TextBlock Style="{StaticResource FloatButtonBadgeTextStyle}" Text="9" />
                                            </Border>
                                        </Grid>
                                        <Grid Style="{StaticResource FloatButtonBadgeHostStyle}">
                                            <nc:NFloatButton Position="Relative">
                                                <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                            </nc:NFloatButton>
                                            <Border Style="{StaticResource FloatButtonBadgeStyle}">
                                                <TextBlock Style="{StaticResource FloatButtonBadgeTextStyle}" Text="99+" />
                                            </Border>
                                        </Grid>
                                        <Grid Style="{StaticResource FloatButtonBadgeHostStyle}">
                                            <nc:NFloatButton Position="Relative">
                                                <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                            </nc:NFloatButton>
                                            <Border Style="{StaticResource FloatButtonBadgeDotStyle}" />
                                        </Grid>
                                        <Grid Style="{StaticResource FloatButtonBadgeHostStyle}">
                                            <nc:NFloatButton Position="Relative">
                                                <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                            </nc:NFloatButton>
                                            <Border Background="{DynamicResource Theme.Text.Secondary.Brush}" Style="{StaticResource FloatButtonBadgeDotStyle}" />
                                        </Grid>
                                        <Grid Style="{StaticResource FloatButtonBadgeHostStyle}">
                                            <nc:NFloatButton Position="Relative">
                                                <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                            </nc:NFloatButton>
                                            <Border Style="{StaticResource FloatButtonBadgeStyle}">
                                                <TextBlock Style="{StaticResource FloatButtonBadgeTextStyle}" Text="&#26032;" />
                                            </Border>
                                        </Grid>
                                        <Grid Width="40" Height="40">
                                            <nc:NFloatButton Position="Relative">
                                                <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                            </nc:NFloatButton>
                                            <Border Background="{DynamicResource Theme.Text.Primary.Brush}" Style="{StaticResource FloatButtonBadgeStyle}">
                                                <TextBlock Style="{StaticResource FloatButtonBadgeTextStyle}" Text="9" />
                                            </Border>
                                        </Grid>
                                    </WrapPanel>
                                </StackPanel>
                            </showMeTheXaml:XamlDisplay>
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionTooltip" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="气泡提示" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <showMeTheXaml:XamlDisplay Style="{StaticResource AvalonEditXamlDisplay}" UniqueKey="FloatButtonDocsPage3">
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,18"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="当前仓库还没有单独的 NTooltip，所以这里先复用 WPF ToolTip，把官方交互对齐出来。" />
                                    <nc:NFloatButton
                                        HorizontalAlignment="Left"
                                        Position="Relative"
                                        ToolTip="这个故事还没有完结"
                                        ToolTipService.Placement="Right">
                                        <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                    </nc:NFloatButton>
                                </StackPanel>
                            </showMeTheXaml:XamlDisplay>
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionDescription" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="描述" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <showMeTheXaml:XamlDisplay Style="{StaticResource AvalonEditXamlDisplay}" UniqueKey="FloatButtonDocsPage4">
                                <Border Margin="30,24,30,24" Style="{StaticResource DemoStageStyle}">
                                    <Canvas Height="120">
                                        <nc:NFloatButton
                                            Canvas.Left="0"
                                            Canvas.Top="0"
                                            Position="Relative"
                                            Shape="Square">
                                            <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                            <nc:NFloatButton.Description>
                                                文档
                                            </nc:NFloatButton.Description>
                                        </nc:NFloatButton>
                                        <nc:NFloatButton
                                            Canvas.Left="60"
                                            Canvas.Top="0"
                                            Position="Relative"
                                            Shape="Square">
                                            <nc:NFloatButton.Description>
                                                文档
                                            </nc:NFloatButton.Description>
                                        </nc:NFloatButton>
                                        <nc:NFloatButton
                                            Canvas.Left="120"
                                            Canvas.Top="0"
                                            Position="Relative"
                                            Shape="Square">
                                            <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                            <nc:NFloatButton.Description>
                                                很长很长的文档
                                            </nc:NFloatButton.Description>
                                        </nc:NFloatButton>
                                    </Canvas>
                                </Border>
                            </showMeTheXaml:XamlDisplay>
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionGroup" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="按钮组" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <showMeTheXaml:XamlDisplay Style="{StaticResource AvalonEditXamlDisplay}" UniqueKey="FloatButtonDocsPage5">
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,18"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="可以任意组合元素，实现更多的功能。" />
                                    <WrapPanel>
                                        <nc:NFloatButtonGroup
                                            Margin="0,0,24,0"
                                            VerticalAlignment="Top"
                                            Position="Relative"
                                            Shape="Square">
                                            <nc:NFloatButton Position="Relative">
                                                <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                            </nc:NFloatButton>
                                            <nc:NFloatButton Position="Relative">
                                                <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                            </nc:NFloatButton>
                                            <nc:NFloatButton Position="Relative">
                                                <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                            </nc:NFloatButton>
                                            <nc:NFloatButton Position="Relative">
                                                <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                            </nc:NFloatButton>
                                        </nc:NFloatButtonGroup>

                                        <nc:NFloatButtonGroup Position="Relative">
                                            <nc:NFloatButton Position="Relative">
                                                <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                            </nc:NFloatButton>
                                            <nc:NFloatButton Position="Relative">
                                                <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                            </nc:NFloatButton>
                                            <nc:NFloatButton Position="Relative">
                                                <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                            </nc:NFloatButton>
                                            <nc:NFloatButton Position="Relative">
                                                <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                            </nc:NFloatButton>
                                        </nc:NFloatButtonGroup>
                                    </WrapPanel>
                                </StackPanel>
                            </showMeTheXaml:XamlDisplay>
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionMenu" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="菜单显示" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <showMeTheXaml:XamlDisplay Style="{StaticResource AvalonEditXamlDisplay}" UniqueKey="FloatButtonDocsPage6">
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,18"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="设定 MenuTrigger 后，更多的 NFloatButton 可被折叠于一个 NFloatButton 中。" />
                                    <WrapPanel>
                                        <nc:NFloatButton
                                            Margin="0,0,24,0"
                                            MenuTrigger="Hover"
                                            Position="Relative"
                                            Type="Primary">
                                            <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                            <nc:NFloatButton.Menu>
                                                <StackPanel>
                                                    <nc:NFloatButton
                                                        Margin="0,0,0,16"
                                                        Position="Relative"
                                                        Shape="Square"
                                                        Type="Primary">
                                                        <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                                    </nc:NFloatButton>
                                                    <nc:NFloatButton Margin="0,0,0,16" Position="Relative">
                                                        <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                                    </nc:NFloatButton>
                                                    <nc:NFloatButton Position="Relative">
                                                        <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                                    </nc:NFloatButton>
                                                </StackPanel>
                                            </nc:NFloatButton.Menu>
                                        </nc:NFloatButton>

                                        <nc:NFloatButton
                                            MenuTrigger="Click"
                                            Position="Relative"
                                            Type="Primary">
                                            <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                            <nc:NFloatButton.Menu>
                                                <StackPanel>
                                                    <nc:NFloatButton
                                                        Margin="0,0,0,16"
                                                        Position="Relative"
                                                        Shape="Square"
                                                        Type="Primary">
                                                        <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                                    </nc:NFloatButton>
                                                    <nc:NFloatButton Margin="0,0,0,16" Position="Relative">
                                                        <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                                    </nc:NFloatButton>
                                                    <nc:NFloatButton Position="Relative">
                                                        <nc:NIcon Data="{StaticResource CheckmarkCircle}" Size="15" />
                                                    </nc:NFloatButton>
                                                </StackPanel>
                                            </nc:NFloatButton.Menu>
                                        </nc:NFloatButton>
                                    </WrapPanel>
                                </StackPanel>
                            </showMeTheXaml:XamlDisplay>
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionApi" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="API" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <TextBlock
                                Margin="30,24,30,24"
                                Style="{StaticResource DocBodyTextStyle}"
                                Text="下面的 API 以 Naive UI Float Button 为基准，对 WPF 版本的属性语义和插槽写法做了对应整理。" />
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionFloatButtonProps" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="FloatButton Props" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <sections:ApiDocTable Margin="30,24,30,24" ItemsSource="{Binding FloatButtonPropsRows}" />
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionFloatButtonGroupProps" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="FloatButtonGroup Props" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <sections:ApiDocTable Margin="30,24,30,24" ItemsSource="{Binding FloatButtonGroupPropsRows}" />
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionFloatButtonSlots" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="FloatButton Slots" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <sections:ApiDocTable Margin="30,24,30,24" ItemsSource="{Binding FloatButtonSlotsRows}" />
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Column="1" Background="{DynamicResource Theme.Surface.0.Brush}">
            <nc:NMenu
                Margin="20,36,20,20"
                DisplayMemberPath="Label"
                ItemInvoked="HandleOutlineItemInvoked"
                ItemsSource="{Binding OutlineItems}"
                SelectedValuePath="TargetName" />
        </Border>
    </Grid>
</UserControl>


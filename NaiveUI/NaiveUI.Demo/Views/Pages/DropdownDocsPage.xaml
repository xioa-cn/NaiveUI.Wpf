        <Style x:Key="DropdownHintTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Secondary.Brush}" />
            <Setter Property="LineHeight" Value="24" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource Theme.Surface.0.Brush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Border
                Background="{DynamicResource Theme.Surface.0.Brush}"
                BorderBrush="{DynamicResource Theme.Border.Brush}"
                BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl Margin="10,18,10,18" ItemsSource="{Binding SidebarCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,18">
                                    <TextBlock Style="{StaticResource SidebarCategoryHeaderTextStyle}" Text="{Binding HeaderText}" />
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Click="HandleSidebarItemClick" Style="{StaticResource SidebarNavButtonStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Style="{StaticResource SidebarNavTitleTextStyle}" Text="{Binding Title}" />
                                                            <TextBlock Style="{StaticResource SidebarNavSubtitleTextStyle}" Text="{Binding Subtitle}" />
                                                        </StackPanel>
                                                        <Border
                                                            Grid.Column="1"
                                                            Margin="10,0,0,0"
                                                            Padding="7,1"
                                                            VerticalAlignment="Center"
                                                            Background="#E6F9F0"
                                                            CornerRadius="11"
                                                            Visibility="{Binding HasBadge, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <TextBlock
                                                                FontSize="12"
                                                                Foreground="#18A058"
                                                                Text="{Binding BadgeText}" />
                                                        </Border>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Button
                Width="32"
                Height="32"
                Margin="0,300,-16,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Content="&#xE76B;"
                Style="{StaticResource SidebarCollapseButtonStyle}" />
        </Grid>

        <ScrollViewer
            x:Name="DocumentScrollViewer"
            Grid.Column="1"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="68,34,18,34">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        FontSize="48"
                        FontWeight="Bold"
                        Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                        Text="下拉菜单" />
                </StackPanel>

                <TextBlock
                    Margin="0,26,0,0"
                    FontSize="18"
                    Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                    Text="在一个紧凑的浮层里承载一组操作、导航入口或多级联动菜单，交互和视觉尽量贴近 Naive UI。" />



                <TextBlock
                    Margin="0,52,0,28"
                    FontSize="36"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                    Text="演示" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <nu:CardElement x:Name="SectionBasic" Margin="0,0,0,20">
                            <nu:CardElement.HeaderElement>
                                <Grid Margin="30,28,30,0">
                                    <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="基础" />
                                </Grid>
                            </nu:CardElement.HeaderElement>
                            <nu:CardElement.ContentElement>
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="最基础的下拉菜单用法。默认使用悬浮触发，菜单项样式、阴影和圆角都按 Naive UI 的方向做了还原。" />
                                    <nc:NDropdown Select="HandleDropdownSelect">
                                        <nc:NDropdown.Options>
                                            <nc:NDropdownOption
                                                Key="滨海湾金沙，新加坡"
                                                Disabled="True"
                                                Label="滨海湾金沙，新加坡" />
                                            <nc:NDropdownOption Key="布朗酒店，伦敦" Label="布朗酒店，伦敦" />
                                            <nc:NDropdownOption Key="亚特兰蒂斯巴哈马，拿骚" Label="亚特兰蒂斯巴哈马，拿骚" />
                                            <nc:NDropdownOption Key="比佛利山庄酒店，洛杉矶" Label="比佛利山庄酒店，洛杉矶" />
                                        </nc:NDropdown.Options>
                                        <nc:NButton>找个地方休息</nc:NButton>
                                    </nc:NDropdown>
                                </StackPanel>
                            </nu:CardElement.ContentElement>
                        </nu:CardElement>

                        <nu:CardElement x:Name="SectionTrigger" Margin="0,0,0,20">
                            <nu:CardElement.HeaderElement>
                                <Grid Margin="30,28,30,0">
                                    <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="触发方式" />
                                </Grid>
                            </nu:CardElement.HeaderElement>
                            <nu:CardElement.ContentElement>
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="支持悬浮、点击、手动控制和右键菜单四种常见触发方式。手动模式下，通过 Show 属性直接控制显示状态。" />
                                    <WrapPanel ItemHeight="34" ItemWidth="118">
                                        <nc:NDropdown Select="HandleDropdownSelect" Trigger="Hover">
                                            <nc:NDropdown.Options>
                                                <nc:NDropdownOption
                                                    Key="滨海湾金沙，新加坡"
                                                    Disabled="True"
                                                    Label="滨海湾金沙，新加坡" />
                                                <nc:NDropdownOption Key="布朗酒店，伦敦" Label="布朗酒店，伦敦" />
                                                <nc:NDropdownOption Key="亚特兰蒂斯巴哈马，拿骚" Label="亚特兰蒂斯巴哈马，拿骚" />
                                                <nc:NDropdownOption Key="比佛利山庄酒店，洛杉矶" Label="比佛利山庄酒店，洛杉矶" />
                                            </nc:NDropdown.Options>
                                            <nc:NButton>悬浮触发</nc:NButton>
                                        </nc:NDropdown>

                                        <nc:NDropdown Select="HandleDropdownSelect" Trigger="Click">
                                            <nc:NDropdown.Options>
                                                <nc:NDropdownOption
                                                    Key="滨海湾金沙，新加坡"
                                                    Disabled="True"
                                                    Label="滨海湾金沙，新加坡" />
                                                <nc:NDropdownOption Key="布朗酒店，伦敦" Label="布朗酒店，伦敦" />
                                                <nc:NDropdownOption Key="亚特兰蒂斯巴哈马，拿骚" Label="亚特兰蒂斯巴哈马，拿骚" />
                                                <nc:NDropdownOption Key="比佛利山庄酒店，洛杉矶" Label="比佛利山庄酒店，洛杉矶" />
                                            </nc:NDropdown.Options>
                                            <nc:NButton>点击触发</nc:NButton>
                                        </nc:NDropdown>

                                        <nc:NDropdown
                                            Select="HandleDropdownSelect"
                                            Show="{Binding ManualDropdownVisible}"
                                            Trigger="Manual">
                                            <nc:NDropdown.Options>
                                                <nc:NDropdownOption
                                                    Key="滨海湾金沙，新加坡"
                                                    Disabled="True"
                                                    Label="滨海湾金沙，新加坡" />
                                                <nc:NDropdownOption Key="布朗酒店，伦敦" Label="布朗酒店，伦敦" />
                                                <nc:NDropdownOption Key="亚特兰蒂斯巴哈马，拿骚" Label="亚特兰蒂斯巴哈马，拿骚" />
                                                <nc:NDropdownOption Key="比佛利山庄酒店，洛杉矶" Label="比佛利山庄酒店，洛杉矶" />

                                            </nc:NDropdown.Options>
                                            <nc:NButton Click="HandleManualDropdownButtonClick">手动控制</nc:NButton>
                                        </nc:NDropdown>
                                    </WrapPanel>
                                    <nc:NDropdown
                                        Margin="0,18,0,0"
                                        Select="HandleDropdownSelect"
                                        Trigger="ContextMenu">
                                        <nc:NDropdown.Options>
                                            <nc:NDropdownOption Key="复制当前内容" Label="复制当前内容" />
                                            <nc:NDropdownOption Key="另存为草稿" Label="另存为草稿" />
                                            <nc:NDropdownDividerOption />
                                            <nc:NDropdownOption Key="删除这条记录" Label="删除这条记录" />
                                            <nc:NDropdownOption Key="查看操作历史" Label="查看操作历史" />
                                        </nc:NDropdown.Options>
                                        <Border
                                            Width="250"
                                            Padding="14,12"
                                            Background="{DynamicResource Theme.Surface.1.Brush}"
                                            CornerRadius="10">
                                            <TextBlock Foreground="{DynamicResource Theme.Text.Secondary.Brush}" Text="在这里点右键，体验 ContextMenu 触发。" />
                                        </Border>
                                    </nc:NDropdown>
                                </StackPanel>
                            </nu:CardElement.ContentElement>
                        </nu:CardElement>

                        <nu:CardElement x:Name="SectionAction" Margin="0,0,0,20">
                            <nu:CardElement.HeaderElement>
                                <Grid Margin="30,28,30,0">
                                    <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="单项交互" />
                                </Grid>
                            </nu:CardElement.HeaderElement>
                            <nu:CardElement.ContentElement>
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="除了统一的 Select 事件外，也可以直接给单个 NDropdownOption 挂 Click 或 Command。Click 更适合代码后置，Command 更适合 MVVM。" />
                                    <Border
                                        Padding="14,12"
                                        Background="{DynamicResource Theme.Surface.1.Brush}"
                                        CornerRadius="10">
                                        <TextBlock Foreground="{DynamicResource Theme.Text.Secondary.Brush}" Text="{Binding OptionActionText}" />
                                    </Border>
                                    <WrapPanel Margin="0,18,0,0">
                                        <nc:NDropdown
                                            Margin="0,0,12,12"
                                            Select="HandleDropdownSelect"
                                            Trigger="Click">
                                            <nc:NDropdown.Options>
                                                <nc:NDropdownOption
                                                    Key="复制链接"
                                                    Click="HandleOptionClick"
                                                    Label="复制链接" />
                                                <nc:NDropdownOption
                                                    Key="分享给同事"
                                                    Click="HandleOptionClick"
                                                    Label="分享给同事" />
                                                <nc:NDropdownOption
                                                    Key="固定到顶部"
                                                    Click="HandleOptionClick"
                                                    Label="固定到顶部" />
                                            </nc:NDropdown.Options>
                                            <nc:NButton>单项点击</nc:NButton>
                                        </nc:NDropdown>

                                        <nc:NDropdown
                                            Margin="0,0,12,12"
                                            Select="HandleDropdownSelect"
                                            Trigger="Click">
                                            <nc:NDropdown.Options>
                                                <nc:NDropdownOption
                                                    Key="归档当前消息"
                                                    Command="{Binding OptionActionCommand}"
                                                    CommandParameter="测试命令参数"
                                                    Label="归档当前消息" />
                                                <nc:NDropdownOption
                                                    Key="导出当前报表"
                                                    Command="{Binding OptionActionCommand}"
                                                    CommandParameter="执行批量导出任务"
                                                    Label="导出当前报表" />
                                                <nc:NDropdownOption
                                                    Key="标记为稍后处理"
                                                    Command="{Binding OptionActionCommand}"
                                                    Label="标记为稍后处理" />
                                            </nc:NDropdown.Options>
                                            <nc:NButton Kind="Secondary">单项命令</nc:NButton>
                                        </nc:NDropdown>

                                        <nc:NDropdown
                                            Margin="0,0,12,12"
                                            Select="HandleDropdownSelect"
                                            Trigger="Click">
                                            <nc:NDropdown.Options>
                                                <nc:NDropdownOption Key="绑定标题" Label="{Binding BoundOptionLabel}" />
                                                <nc:NDropdownOption Key="静态标题" Label="静态标题，用来对比" />
                                            </nc:NDropdown.Options>
                                            <nc:NButton Kind="Tertiary">标签绑定</nc:NButton>
                                        </nc:NDropdown>
                                    </WrapPanel>
                                </StackPanel>
                            </nu:CardElement.ContentElement>
                        </nu:CardElement>

                        <nu:CardElement x:Name="SectionGroup" Margin="0,0,0,20">
                            <nu:CardElement.HeaderElement>
                                <Grid Margin="30,28,30,0">
                                    <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="分组与分割线" />
                                </Grid>
                            </nu:CardElement.HeaderElement>
                            <nu:CardElement.ContentElement>
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="分组标题、分割线和右侧附加信息都可以组合使用，适合把一长串操作拆成更清晰的结构。" />
                                    <nc:NDropdown
                                        Placement="BottomStart"
                                        Select="HandleDropdownSelect"
                                        Trigger="Click">
                                        <nc:NDropdown.Options>
                                            <nc:NDropdownGroupOption Label="快速操作">
                                                <nc:NDropdownOption Key="新建项目" Label="新建项目">
                                                    <nc:NDropdownOption.Suffix>
                                                        <TextBlock Foreground="{DynamicResource Theme.Text.Tertiary.Brush}" Text="Ctrl+N" />
                                                    </nc:NDropdownOption.Suffix>
                                                </nc:NDropdownOption>
                                                <nc:NDropdownOption Key="导出配置" Label="导出配置" />
                                            </nc:NDropdownGroupOption>
                                            <nc:NDropdownDividerOption />
                                            <nc:NDropdownGroupOption Label="系统设置">
                                                <nc:NDropdownOption Key="权限中心" Label="权限中心" />
                                                <nc:NDropdownOption Key="主题切换" Label="主题切换" />
                                                <nc:NDropdownOption
                                                    Key="高级实验室"
                                                    Disabled="True"
                                                    Label="高级实验室" />
                                            </nc:NDropdownGroupOption>
                                        </nc:NDropdown.Options>
                                        <nc:NButton Kind="Tertiary">查看结构化菜单</nc:NButton>
                                    </nc:NDropdown>
                                </StackPanel>
                            </nu:CardElement.ContentElement>
                        </nu:CardElement>

                        <nu:CardElement x:Name="SectionPlacement" Margin="0,0,0,20">
                            <nu:CardElement.HeaderElement>
                                <Grid Margin="30,28,30,0">
                                    <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="弹出位置" />
                                </Grid>
                            </nu:CardElement.HeaderElement>
                            <nu:CardElement.ContentElement>
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="支持主方向和起止对齐变体。对于新手来说，可以简单理解成：BottomStart 是下方左对齐，TopEnd 是上方右对齐，RightStart 是右侧顶对齐。" />
                                    <WrapPanel Width="420">
                                        <nc:NDropdown
                                            Placement="BottomStart"
                                            Select="HandleDropdownSelect"
                                            Trigger="Click">
                                            <nc:NDropdown.Options>
                                                <nc:NDropdownOption Key="滨海湾金沙，新加坡" Label="滨海湾金沙，新加坡" />
                                                <nc:NDropdownOption Key="布朗酒店，伦敦" Label="布朗酒店，伦敦" />
                                                <nc:NDropdownOption Key="亚特兰蒂斯巴哈马，拿骚" Label="亚特兰蒂斯巴哈马，拿骚" />
                                            </nc:NDropdown.Options>
                                            <nc:NButton Margin="0,0,12,12">下方左对齐</nc:NButton>
                                        </nc:NDropdown>

                                        <nc:NDropdown
                                            Placement="BottomEnd"
                                            Select="HandleDropdownSelect"
                                            Trigger="Click">
                                            <nc:NDropdown.Options>
                                                <nc:NDropdownOption Key="滨海湾金沙，新加坡" Label="滨海湾金沙，新加坡" />
                                                <nc:NDropdownOption Key="布朗酒店，伦敦" Label="布朗酒店，伦敦" />
                                                <nc:NDropdownOption Key="亚特兰蒂斯巴哈马，拿骚" Label="亚特兰蒂斯巴哈马，拿骚" />
                                            </nc:NDropdown.Options>
                                            <nc:NButton Margin="0,0,12,12">下方右对齐</nc:NButton>
                                        </nc:NDropdown>

                                        <nc:NDropdown
                                            Placement="TopStart"
                                            Select="HandleDropdownSelect"
                                            Trigger="Click">
                                            <nc:NDropdown.Options>
                                                <nc:NDropdownOption Key="滨海湾金沙，新加坡" Label="滨海湾金沙，新加坡" />
                                                <nc:NDropdownOption Key="布朗酒店，伦敦" Label="布朗酒店，伦敦" />
                                                <nc:NDropdownOption Key="亚特兰蒂斯巴哈马，拿骚" Label="亚特兰蒂斯巴哈马，拿骚" />
                                            </nc:NDropdown.Options>
                                            <nc:NButton Margin="0,0,12,12">上方左对齐</nc:NButton>
                                        </nc:NDropdown>

                                        <nc:NDropdown
                                            Placement="RightStart"
                                            Select="HandleDropdownSelect"
                                            Trigger="Click">
                                            <nc:NDropdown.Options>
                                                <nc:NDropdownOption Key="滨海湾金沙，新加坡" Label="滨海湾金沙，新加坡" />
                                                <nc:NDropdownOption Key="布朗酒店，伦敦" Label="布朗酒店，伦敦" />
                                                <nc:NDropdownOption Key="亚特兰蒂斯巴哈马，拿骚" Label="亚特兰蒂斯巴哈马，拿骚" />
                                            </nc:NDropdown.Options>
                                            <nc:NButton Margin="0,0,12,12">右侧顶对齐</nc:NButton>
                                        </nc:NDropdown>
                                    </WrapPanel>
                                </StackPanel>
                            </nu:CardElement.ContentElement>
                        </nu:CardElement>

                        <nu:CardElement x:Name="SectionCustomContent" Margin="0,0,0,20">
                            <nu:CardElement.HeaderElement>
                                <Grid Margin="30,28,30,0">
                                    <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="自定义内容" />
                                </Grid>
                            </nu:CardElement.HeaderElement>
                            <nu:CardElement.ContentElement>
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="通过 NDropdownRenderOption 可以在菜单中插入一段完整的自定义内容，适合放说明卡片、推荐操作或快捷入口。" />
                                    <nc:NDropdown
                                        Placement="BottomStart"
                                        Select="HandleDropdownSelect"
                                        Trigger="Click">
                                        <nc:NDropdown.Options>
                                            <nc:NDropdownRenderOption>
                                                <Border
                                                    Margin="4,2"
                                                    Padding="12,10"
                                                    Background="{DynamicResource Theme.Surface.1.Brush}"
                                                    CornerRadius="6">
                                                    <StackPanel>
                                                        <TextBlock
                                                            FontWeight="SemiBold"
                                                            Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                                                            Text="推荐操作" />
                                                        <TextBlock
                                                            Margin="0,6,0,0"
                                                            Style="{StaticResource DropdownHintTextStyle}"
                                                            Text="先处理权限、主题和通知，再继续进入高级设置。" />
                                                    </StackPanel>
                                                </Border>
                                            </nc:NDropdownRenderOption>
                                            <nc:NDropdownDividerOption />
                                            <nc:NDropdownOption Key="进入权限中心" Label="进入权限中心" />
                                            <nc:NDropdownOption Key="打开主题设置" Label="打开主题设置" />
                                        </nc:NDropdown.Options>
                                        <nc:NButton Kind="Secondary">打开推荐菜单</nc:NButton>
                                    </nc:NDropdown>
                                </StackPanel>
                            </nu:CardElement.ContentElement>
                        </nu:CardElement>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <nu:CardElement x:Name="SectionIcon" Margin="0,0,0,20">
                            <nu:CardElement.HeaderElement>
                                <Grid Margin="30,28,30,0">
                                    <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="图标" />
                                </Grid>
                            </nu:CardElement.HeaderElement>
                            <nu:CardElement.ContentElement>
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="每个菜单项都可以在左侧附带图标，用来强化“资料”“编辑”“退出”这类语义。" />
                                    <nc:NDropdown Select="HandleDropdownSelect" Trigger="Click">
                                        <nc:NDropdown.Options>
                                            <nc:NDropdownOption Key="用户资料" Label="用户资料">
                                                <nc:NDropdownOption.Icon>
                                                    <nc:NIcon Data="{StaticResource DropdownUserGeometry}" />
                                                </nc:NDropdownOption.Icon>
                                            </nc:NDropdownOption>
                                            <nc:NDropdownOption Key="编辑资料" Label="编辑资料">
                                                <nc:NDropdownOption.Icon>
                                                    <nc:NIcon Data="{StaticResource DropdownEditGeometry}" />
                                                </nc:NDropdownOption.Icon>
                                            </nc:NDropdownOption>
                                            <nc:NDropdownOption Key="退出登录" Label="退出登录">
                                                <nc:NDropdownOption.Icon>
                                                    <nc:NIcon Data="{StaticResource DropdownLogoutGeometry}" />
                                                </nc:NDropdownOption.Icon>
                                            </nc:NDropdownOption>
                                        </nc:NDropdown.Options>
                                        <nc:NButton>用户资料</nc:NButton>
                                    </nc:NDropdown>
                                </StackPanel>
                            </nu:CardElement.ContentElement>
                        </nu:CardElement>

                        <nu:CardElement x:Name="SectionCascade" Margin="0,0,0,20">
                            <nu:CardElement.HeaderElement>
                                <Grid Margin="30,28,30,0">
                                    <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="多级联动" />
                                </Grid>
                            </nu:CardElement.HeaderElement>
                            <nu:CardElement.ContentElement>
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="使用 NDropdownCombineOption 可以声明多级级联菜单。鼠标悬浮会向右展开子菜单；组合项自身只负责展开，不支持 Click 或 Command，真正执行动作的是内部叶子 NDropdownOption。" />
                                    <nc:NDropdown
                                        Placement="BottomStart"
                                        Select="HandleDropdownSelect"
                                        Trigger="Click">
                                        <nc:NDropdown.Options>
                                            <nc:NDropdownCombineOption Key="内容中心" Label="内容中心">
                                                <nc:NDropdownCombineOption.Icon>
                                                    <nc:NIcon Data="{StaticResource DropdownUserGeometry}" />
                                                </nc:NDropdownCombineOption.Icon>
                                                <nc:NDropdownOption
                                                    Key="最近更新"
                                                    Command="{Binding OptionActionCommand}"
                                                    Label="最近更新" />
                                                <nc:NDropdownCombineOption Key="品牌素材" Label="品牌素材">
                                                    <nc:NDropdownOption
                                                        Key="Logo 规范"
                                                        Click="HandleOptionClick"
                                                        Label="Logo 规范" />
                                                    <nc:NDropdownCombineOption Key="海报模板" Label="海报模板">
                                                        <nc:NDropdownOption
                                                            Key="春季活动海报"
                                                            Command="{Binding OptionActionCommand}"
                                                            CommandParameter="春季活动海报"
                                                            Label="春季活动海报" />
                                                        <nc:NDropdownOption
                                                            Key="招聘海报"
                                                            Click="HandleOptionClick"
                                                            Label="招聘海报" />
                                                    </nc:NDropdownCombineOption>
                                                </nc:NDropdownCombineOption>
                                            </nc:NDropdownCombineOption>
                                            <nc:NDropdownDividerOption />
                                            <nc:NDropdownCombineOption Key="团队空间" Label="团队空间">
                                                <nc:NDropdownCombineOption.Icon>
                                                    <nc:NIcon Data="{StaticResource DropdownEditGeometry}" />
                                                </nc:NDropdownCombineOption.Icon>
                                                <nc:NDropdownOption
                                                    Key="项目看板"
                                                    Click="HandleOptionClick"
                                                    Label="项目看板" />
                                                <nc:NDropdownCombineOption Key="共享模板" Label="共享模板">
                                                    <nc:NDropdownOption
                                                        Key="周报模板"
                                                        Command="{Binding OptionActionCommand}"
                                                        Label="周报模板" />
                                                    <nc:NDropdownOption
                                                        Key="复盘模板"
                                                        Click="HandleOptionClick"
                                                        Label="复盘模板" />
                                                </nc:NDropdownCombineOption>
                                            </nc:NDropdownCombineOption>
                                            <nc:NDropdownOption Key="回收站" Label="回收站" />
                                        </nc:NDropdown.Options>
                                        <nc:NButton>多级资源菜单</nc:NButton>
                                    </nc:NDropdown>
                                </StackPanel>
                            </nu:CardElement.ContentElement>
                        </nu:CardElement>

                        <nu:CardElement x:Name="SectionArrow" Margin="0,0,0,20">
                            <nu:CardElement.HeaderElement>
                                <Grid Margin="30,28,30,0">
                                    <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="显示箭头" />
                                </Grid>
                            </nu:CardElement.HeaderElement>
                            <nu:CardElement.ContentElement>
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="ShowArrow 会在浮层边缘加上一个指向触发源的小箭头，更接近 Naive UI 在 Popover 系列里的视觉表现。" />
                                    <nc:NDropdown
                                        Placement="BottomStart"
                                        Select="HandleDropdownSelect"
                                        ShowArrow="True"
                                        Trigger="Click">
                                        <nc:NDropdown.Options>
                                            <nc:NDropdownOption
                                                Key="滨海湾金沙，新加坡"
                                                Disabled="True"
                                                Label="滨海湾金沙，新加坡" />
                                            <nc:NDropdownOption Key="布朗酒店，伦敦" Label="布朗酒店，伦敦" />
                                            <nc:NDropdownOption Key="亚特兰蒂斯巴哈马，拿骚" Label="亚特兰蒂斯巴哈马，拿骚" />
                                            <nc:NDropdownOption Key="比佛利山庄酒店，洛杉矶" Label="比佛利山庄酒店，洛杉矶" />
                                        </nc:NDropdown.Options>
                                        <nc:NButton>带箭头的菜单</nc:NButton>
                                    </nc:NDropdown>
                                </StackPanel>
                            </nu:CardElement.ContentElement>
                        </nu:CardElement>

                        <nu:CardElement x:Name="SectionSize" Margin="0,0,0,20">
                            <nu:CardElement.HeaderElement>
                                <Grid Margin="30,28,30,0">
                                    <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="菜单尺寸" />
                                </Grid>
                            </nu:CardElement.HeaderElement>
                            <nu:CardElement.ContentElement>
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="Small、Medium、Large、Huge 会同步影响菜单项高度、字号以及前后缀宽度，适合匹配不同密度的界面。" />
                                    <WrapPanel Width="420">
                                        <nc:NDropdown
                                            Placement="BottomStart"
                                            Select="HandleDropdownSelect"
                                            Size="Small"
                                            Trigger="Click">
                                            <nc:NDropdown.Options>
                                                <nc:NDropdownOption Key="杰·盖茨比" Label="杰·盖茨比" />
                                                <nc:NDropdownOption Key="黛西·布坎南" Label="黛西·布坎南" />
                                                <nc:NDropdownDividerOption />
                                                <nc:NDropdownOption Key="尼克·卡拉威" Label="尼克·卡拉威" />
                                            </nc:NDropdown.Options>
                                            <nc:NButton Margin="0,0,12,12">小号</nc:NButton>
                                        </nc:NDropdown>

                                        <nc:NDropdown
                                            Placement="BottomStart"
                                            Select="HandleDropdownSelect"
                                            Size="Medium"
                                            Trigger="Click">
                                            <nc:NDropdown.Options>
                                                <nc:NDropdownOption Key="杰·盖茨比" Label="杰·盖茨比" />
                                                <nc:NDropdownOption Key="黛西·布坎南" Label="黛西·布坎南" />
                                                <nc:NDropdownDividerOption />
                                                <nc:NDropdownOption Key="尼克·卡拉威" Label="尼克·卡拉威" />
                                            </nc:NDropdown.Options>
                                            <nc:NButton Margin="0,0,12,12">中号</nc:NButton>
                                        </nc:NDropdown>

                                        <nc:NDropdown
                                            Placement="BottomStart"
                                            Select="HandleDropdownSelect"
                                            Size="Large"
                                            Trigger="Click">
                                            <nc:NDropdown.Options>
                                                <nc:NDropdownOption Key="杰·盖茨比" Label="杰·盖茨比" />
                                                <nc:NDropdownOption Key="黛西·布坎南" Label="黛西·布坎南" />
                                                <nc:NDropdownDividerOption />
                                                <nc:NDropdownOption Key="尼克·卡拉威" Label="尼克·卡拉威" />
                                            </nc:NDropdown.Options>
                                            <nc:NButton Margin="0,0,12,12">大号</nc:NButton>
                                        </nc:NDropdown>

                                        <nc:NDropdown
                                            Placement="BottomStart"
                                            Select="HandleDropdownSelect"
                                            Size="Huge"
                                            Trigger="Click">
                                            <nc:NDropdown.Options>
                                                <nc:NDropdownOption Key="杰·盖茨比" Label="杰·盖茨比" />
                                                <nc:NDropdownOption Key="黛西·布坎南" Label="黛西·布坎南" />
                                                <nc:NDropdownDividerOption />
                                                <nc:NDropdownOption Key="尼克·卡拉威" Label="尼克·卡拉威" />
                                            </nc:NDropdown.Options>
                                            <nc:NButton Margin="0,0,12,12">超大号</nc:NButton>
                                        </nc:NDropdown>
                                    </WrapPanel>
                                </StackPanel>
                            </nu:CardElement.ContentElement>
                        </nu:CardElement>
                    </StackPanel>
                </Grid>

                <nu:CardElement x:Name="SectionApi" Margin="0,20,0,20">
                    <nu:CardElement.HeaderElement>
                        <Grid Margin="30,28,30,0">
                            <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="API" />
                        </Grid>
                    </nu:CardElement.HeaderElement>
                    <nu:CardElement.ContentElement>
                        <TextBlock
                            Margin="30,24,30,24"
                            Style="{StaticResource DocBodyTextStyle}"
                            Text="下面的接口表按当前 WPF Dropdown 实现整理。NDropdownOption 继续保持轻量叶子项写法，多级级联场景请使用 NDropdownCombineOption。" />
                    </nu:CardElement.ContentElement>
                </nu:CardElement>

                <nu:CardElement x:Name="SectionDropdownProps" Margin="0,0,0,20">
                    <nu:CardElement.HeaderElement>
                        <Grid Margin="30,28,30,0">
                            <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="Dropdown Props" />
                        </Grid>
                    </nu:CardElement.HeaderElement>
                    <nu:CardElement.ContentElement>
                        <sections:ApiDocTable Margin="30,24,30,24" ItemsSource="{Binding DropdownPropsRows}" />
                    </nu:CardElement.ContentElement>
                </nu:CardElement>

                <nu:CardElement x:Name="SectionDropdownOptionProps" Margin="0,0,0,20">
                    <nu:CardElement.HeaderElement>
                        <Grid Margin="30,28,30,0">
                            <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="DropdownOption Props" />
                        </Grid>
                    </nu:CardElement.HeaderElement>
                    <nu:CardElement.ContentElement>
                        <sections:ApiDocTable Margin="30,24,30,24" ItemsSource="{Binding DropdownOptionRows}" />
                    </nu:CardElement.ContentElement>
                </nu:CardElement>

                <nu:CardElement x:Name="SectionDropdownOtherTypes" Margin="0,0,0,20">
                    <nu:CardElement.HeaderElement>
                        <Grid Margin="30,28,30,0">
                            <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="Other Type" />
                        </Grid>
                    </nu:CardElement.HeaderElement>
                    <nu:CardElement.ContentElement>
                        <sections:ApiDocTable Margin="30,24,30,24" ItemsSource="{Binding DropdownOtherOptionRows}" />
                    </nu:CardElement.ContentElement>
                </nu:CardElement>

                <nu:CardElement x:Name="SectionDropdownSlots" Margin="0,0,0,20">
                    <nu:CardElement.HeaderElement>
                        <Grid Margin="30,28,30,0">
                            <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="Dropdown Slots" />
                        </Grid>
                    </nu:CardElement.HeaderElement>
                    <nu:CardElement.ContentElement>
                        <sections:ApiDocTable Margin="30,24,30,24" ItemsSource="{Binding DropdownSlotsRows}" />
                    </nu:CardElement.ContentElement>
                </nu:CardElement>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Column="2" Background="{DynamicResource Theme.Surface.0.Brush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,36,20,20">
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="基础"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionBasic" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="图标"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionIcon" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="触发方式"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionTrigger" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="单项交互"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionAction" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="多级联动"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionCascade" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="分组与分割线"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionGroup" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="显示箭头"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionArrow" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="弹出位置"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionPlacement" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="菜单尺寸"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionSize" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="自定义内容"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionCustomContent" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="接口说明"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionApi" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="下拉菜单属性"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionDropdownProps" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="菜单项与组合项属性"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionDropdownOptionProps" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="其他类型"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionDropdownOtherTypes" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="触发插槽"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionDropdownSlots" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

<UserControl
    x:Class="NaiveUI.Demo.Views.Pages.DocsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:shell="clr-namespace:NaiveUI.Demo.Views.Shell"
    xmlns:viewModels="clr-namespace:NaiveUI.Demo.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewModels:DocsPageViewModel}"
    mc:Ignorable="d">
    <Grid Background="{DynamicResource Theme.Surface.0.Brush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <shell:DocsSidebarShell
            Grid.Column="0"
            SidebarCategories="{Binding SidebarCategories}"
            SidebarItemInvoked="HandleSidebarItemInvoked" />

        <ContentControl
            Grid.Column="1"
            Margin="0,15,15,15"
            Content="{Binding CurrentContentView}" />

    </Grid>
</UserControl>

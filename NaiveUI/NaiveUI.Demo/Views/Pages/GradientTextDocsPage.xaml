<UserControl
    x:Class="NaiveUI.Demo.Views.Pages.GradientTextDocsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:nc="clr-namespace:NaiveUI.NControls.Controls;assembly=NaiveUI.NControls"
    xmlns:nu="clr-namespace:NaiveUI.NControls.ControlsExample;assembly=NaiveUI.NControls"
    xmlns:sections="clr-namespace:NaiveUI.Demo.Views.Sections"
    xmlns:showMeTheXaml="clr-namespace:ShowMeTheXAML;assembly=ShowMeTheXAML"
    xmlns:viewModels="clr-namespace:NaiveUI.Demo.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewModels:GradientTextDocsPageViewModel}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="SectionCardHeaderTitleStyle"
            BasedOn="{StaticResource DocSectionTitleStyle}"
            TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
        </Style>

        <Style x:Key="GradientTextLineStyle" TargetType="{x:Type nc:NGradientText}">
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource Theme.Surface.0.Brush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="25,34,18,34">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        FontSize="48"
                        FontWeight="Bold"
                        Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                        Text="渐变文字 Gradient Text" />
                </StackPanel>

                <TextBlock
                    Margin="0,26,0,0"
                    FontSize="18"
                    Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                    Text="这个东西看起来没啥用，实际上确实没啥用。" />

                <TextBlock
                    Margin="0,52,0,28"
                    FontSize="36"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                    Text="演示" />

                <StackPanel>
                    <nu:CardElement x:Name="SectionBasic" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="基础用法" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <showMeTheXaml:XamlDisplay Style="{StaticResource AvalonEditXamlDisplay}" UniqueKey="GradientTextDocsPage1">
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="它有不同的类型。" />
                                    <StackPanel>
                                        <nc:NGradientText
                                            Style="{StaticResource GradientTextLineStyle}"
                                            Text="炸了"
                                            Type="Error" />
                                        <nc:NGradientText
                                            Style="{StaticResource GradientTextLineStyle}"
                                            Text="噢"
                                            Type="Info" />
                                        <nc:NGradientText
                                            Style="{StaticResource GradientTextLineStyle}"
                                            Text="注意"
                                            Type="Warning" />
                                        <nc:NGradientText
                                            Margin="0"
                                            Text="成了"
                                            Type="Success" />
                                    </StackPanel>
                                </StackPanel>
                            </showMeTheXaml:XamlDisplay>
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionSize" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="尺寸" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <showMeTheXaml:XamlDisplay Style="{StaticResource AvalonEditXamlDisplay}" UniqueKey="GradientTextDocsPage2">
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="其实用 CSS 也挺方便的。" />
                                    <StackPanel>
                                        <WrapPanel Margin="0,0,0,10">
                                            <nc:NGradientText
                                                Margin="0,0,18,0"
                                                FontSize="36"
                                                Text="Live Forever"
                                                Type="Info" />
                                            <nc:NGradientText
                                                FontSize="36"
                                                Text="Live Forever"
                                                Type="Danger" />
                                        </WrapPanel>
                                        <nc:NGradientText
                                            Margin="0,0,0,10"
                                            Size="24"
                                            Text="Married with Children"
                                            Type="Warning" />
                                        <nc:NGradientText
                                            Margin="0"
                                            Size="24"
                                            Text="Back in the USSR"
                                            Type="Success" />
                                    </StackPanel>
                                </StackPanel>
                            </showMeTheXaml:XamlDisplay>
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionCustom" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="定制" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <showMeTheXaml:XamlDisplay Style="{StaticResource AvalonEditXamlDisplay}" UniqueKey="GradientTextDocsPage3">
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="靠你了。" />
                                    <StackPanel>
                                        <nc:NGradientText
                                            Margin="0,0,0,10"
                                            FontFamily="Algerian"
                                            FontSize="24"
                                            FontStyle="Italic"
                                            FontWeight="DemiBold"
                                            Gradient="linear-gradient(90deg, rgb(85, 85, 85) 0%, rgb(170, 170, 170) 100%)"
                                            Text="字符串写法 linear-gradient" />

                                        <nc:NGradientText
                                            Margin="0,0,0,10"
                                            FontSize="24"
                                            FontStyle="Oblique"
                                            Text="对象写法 Gradient">
                                            <nc:NGradientText.Gradient>
                                                <nc:NGradientTextGradient
                                                    Deg="90"
                                                    From="rgb(85, 85, 85)"
                                                    To="rgb(170, 170, 170)" />
                                            </nc:NGradientText.Gradient>
                                        </nc:NGradientText>

                                        <nc:NGradientText
                                            Margin="0"
                                            Gradient="linear-gradient(90deg, red 0%, green 50%, blue 100%)"
                                            Size="60"
                                            Text="多色字符串写法 linear-gradient" />
                                    </StackPanel>
                                </StackPanel>
                            </showMeTheXaml:XamlDisplay>
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionApi" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="API" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <TextBlock
                                Margin="30,24,30,24"
                                Style="{StaticResource DocBodyTextStyle}"
                                Text="下面的 API 表按 Naive UI Gradient Text 的现有语义映射到 WPF 版本整理。" />
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionGradientTextProps" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="GradientText Props" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <sections:ApiDocTable Margin="30,24,30,24" ItemsSource="{Binding GradientTextPropsRows}" />
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionGradientTextGradientProps" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="GradientTextGradient Props" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <StackPanel Margin="30,24,30,24">
                                <TextBlock
                                    Margin="0,0,0,18"
                                    Style="{StaticResource DocBodyTextStyle}"
                                    Text="当你使用对象形式设置 Gradient 时，可以通过下面 3 个字段描述渐变。" />
                                <sections:ApiDocTable ItemsSource="{Binding GradientTextGradientPropsRows}" />
                            </StackPanel>
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionGradientTextSlots" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="GradientText Slots" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <sections:ApiDocTable Margin="30,24,30,24" ItemsSource="{Binding GradientTextSlotsRows}" />
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Column="1" Background="{DynamicResource Theme.Surface.0.Brush}">
            <nc:NMenu
                Margin="20,36,20,20"
                DisplayMemberPath="Label"
                ItemInvoked="HandleOutlineItemInvoked"
                ItemsSource="{Binding OutlineItems}"
                SelectedValuePath="TargetName" />
        </Border>
    </Grid>
</UserControl>
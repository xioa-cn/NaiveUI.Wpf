<UserControl
    x:Class="NaiveUI.Demo.Views.Pages.CollapseDocsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:nc="clr-namespace:NaiveUI.NControls.Controls;assembly=NaiveUI.NControls"
    xmlns:nu="clr-namespace:NaiveUI.NControls.ControlsExample;assembly=NaiveUI.NControls"
    xmlns:sections="clr-namespace:NaiveUI.Demo.Views.Sections"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style
            x:Key="SectionCardHeaderTitleStyle"
            BasedOn="{StaticResource DocSectionTitleStyle}"
            TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
        </Style>

        <Style x:Key="CollapseExtraButtonStyle" TargetType="{x:Type nc:NButton}">
            <Setter Property="Kind" Value="Text" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style x:Key="CollapseBadgeStyle" TargetType="Border">
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Background" Value="#E8F5E9" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource Theme.Surface.0.Brush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Border
                Background="{DynamicResource Theme.Surface.0.Brush}"
                BorderBrush="{DynamicResource Theme.Border.Brush}"
                BorderThickness="0,0,1,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl Margin="10,18,10,18" ItemsSource="{Binding SidebarCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,18">
                                    <TextBlock Style="{StaticResource SidebarCategoryHeaderTextStyle}" Text="{Binding HeaderText}" />
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Click="HandleSidebarItemClick" Style="{StaticResource SidebarNavButtonStyle}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Style="{StaticResource SidebarNavTitleTextStyle}" Text="{Binding Title}" />
                                                            <TextBlock Style="{StaticResource SidebarNavSubtitleTextStyle}" Text="{Binding Subtitle}" />
                                                        </StackPanel>
                                                        <Border
                                                            Grid.Column="1"
                                                            Margin="10,0,0,0"
                                                            Padding="7,1"
                                                            VerticalAlignment="Center"
                                                            Background="#E6F9F0"
                                                            CornerRadius="11"
                                                            Visibility="{Binding HasBadge, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <TextBlock
                                                                FontSize="12"
                                                                Foreground="#18A058"
                                                                Text="{Binding BadgeText}" />
                                                        </Border>
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <Button
                Width="32"
                Height="32"
                Margin="0,300,-16,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Content="&#xE76B;"
                Style="{StaticResource SidebarCollapseButtonStyle}" />
        </Grid>

        <ScrollViewer
            x:Name="DocumentScrollViewer"
            Grid.Column="1"
            VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="68,34,18,34">
                <StackPanel Orientation="Horizontal">
                    <TextBlock
                        FontSize="48"
                        FontWeight="Bold"
                        Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                        Text="折叠面板" />
                </StackPanel>

                <TextBlock
                    Margin="0,26,0,0"
                    FontSize="18"
                    Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                    Text="用于分组展示信息区域，并在有限空间内通过展开收起管理内容密度。" />

                <TextBlock
                    Margin="0,52,0,28"
                    FontSize="36"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                    Text="演示" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <nu:CardElement x:Name="SectionBasic" Margin="0,0,0,20">
                            <nu:CardElement.HeaderElement>
                                <Grid Margin="30,28,30,0">
                                    <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="基础" />
                                </Grid>
                            </nu:CardElement.HeaderElement>
                            <nu:CardElement.ContentElement>
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="最基础的折叠面板用法，适合按主题分组展示说明、配置项或概览信息。" />
                                    <nc:NCollapse Width="420">
                                        <nc:NCollapseItem Title="平台概览" CollapseName="overview">
                                            <TextBlock TextWrapping="Wrap">将监控、配置和说明按块组织，用户只在需要时展开对应内容。</TextBlock>
                                        </nc:NCollapseItem>
                                        <nc:NCollapseItem Title="数据同步" CollapseName="sync">
                                            <TextBlock TextWrapping="Wrap">支持将同步状态、执行规则和异常提示集中在一个面板中管理。</TextBlock>
                                        </nc:NCollapseItem>
                                        <nc:NCollapseItem Title="发布策略" CollapseName="release">
                                            <TextBlock TextWrapping="Wrap">面向需要分阶段展示详细规则的场景，避免页面一次性堆满长内容。</TextBlock>
                                        </nc:NCollapseItem>
                                    </nc:NCollapse>
                                </StackPanel>
                            </nu:CardElement.ContentElement>
                        </nu:CardElement>

                        <nu:CardElement x:Name="SectionAccordion" Margin="0,0,0,20">
                            <nu:CardElement.HeaderElement>
                                <Grid Margin="30,28,30,0">
                                    <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="手风琴模式" />
                                </Grid>
                            </nu:CardElement.HeaderElement>
                            <nu:CardElement.ContentElement>
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="开启 Accordion 后，同一时刻只保留一个展开项，适合问答、说明书和配置流程。" />
                                    <nc:NCollapse Width="420" Accordion="True">
                                        <nc:NCollapse.DefaultExpandedNames>
                                            <sys:String>faq-1</sys:String>
                                        </nc:NCollapse.DefaultExpandedNames>
                                        <nc:NCollapseItem Title="如何初始化项目？" CollapseName="faq-1">
                                            <TextBlock TextWrapping="Wrap">建议先完成主题、导航和基础表单的搭建，再逐步接入具体业务模块。</TextBlock>
                                        </nc:NCollapseItem>
                                        <nc:NCollapseItem Title="如何控制展开状态？" CollapseName="faq-2">
                                            <TextBlock TextWrapping="Wrap">可以使用 ExpandedNames 管理当前展开项，并在 Accordion 模式下只保留一个名称。</TextBlock>
                                        </nc:NCollapseItem>
                                        <nc:NCollapseItem Title="什么时候适合手风琴？" CollapseName="faq-3">
                                            <TextBlock TextWrapping="Wrap">当用户一次只需要处理一个信息块时，手风琴模式更利于聚焦。</TextBlock>
                                        </nc:NCollapseItem>
                                    </nc:NCollapse>
                                </StackPanel>
                            </nu:CardElement.ContentElement>
                        </nu:CardElement>

                        <nu:CardElement x:Name="SectionDefaultExpanded" Margin="0,0,0,20">
                            <nu:CardElement.HeaderElement>
                                <Grid Margin="30,28,30,0">
                                    <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="默认展开项" />
                                </Grid>
                            </nu:CardElement.HeaderElement>
                            <nu:CardElement.ContentElement>
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="使用 DefaultExpandedNames 可以直接配置初始展开状态，适合默认展示重点内容。" />
                                    <nc:NCollapse Width="420">
                                        <nc:NCollapse.DefaultExpandedNames>
                                            <sys:String>plan</sys:String>
                                            <sys:String>notice</sys:String>
                                        </nc:NCollapse.DefaultExpandedNames>
                                        <nc:NCollapseItem Title="上线计划" CollapseName="plan">
                                            <TextBlock TextWrapping="Wrap">默认展开的内容可用于展示当前最需要用户关注的计划与状态。</TextBlock>
                                        </nc:NCollapseItem>
                                        <nc:NCollapseItem Title="注意事项" CollapseName="notice">
                                            <TextBlock TextWrapping="Wrap">支持一次默认展开多个面板，适合首页提示或入门说明。</TextBlock>
                                        </nc:NCollapseItem>
                                        <nc:NCollapseItem Title="归档记录" CollapseName="archive">
                                            <TextBlock TextWrapping="Wrap">非重点信息默认保持折叠，减少首屏信息干扰。</TextBlock>
                                        </nc:NCollapseItem>
                                    </nc:NCollapse>
                                </StackPanel>
                            </nu:CardElement.ContentElement>
                        </nu:CardElement>

                        <nu:CardElement x:Name="SectionArrowPlacement" Margin="0,0,0,20">
                            <nu:CardElement.HeaderElement>
                                <Grid Margin="30,28,30,0">
                                    <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="箭头位置" />
                                </Grid>
                            </nu:CardElement.HeaderElement>
                            <nu:CardElement.ContentElement>
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="通过 ArrowPlacement 可以控制箭头位于左侧还是右侧，便于匹配不同信息层级和对齐习惯。" />
                                    <nc:NCollapse Width="420" ArrowPlacement="Right">
                                        <nc:NCollapseItem Title="右侧箭头布局" CollapseName="right-1">
                                            <TextBlock TextWrapping="Wrap">当列表标题更长时，将箭头放在右侧可以让文本起点保持整齐。</TextBlock>
                                        </nc:NCollapseItem>
                                        <nc:NCollapseItem Title="更接近设置页结构" CollapseName="right-2">
                                            <TextBlock TextWrapping="Wrap">对于设置面板或说明列表，右侧箭头更接近常见的桌面应用视觉习惯。</TextBlock>
                                        </nc:NCollapseItem>
                                    </nc:NCollapse>
                                </StackPanel>
                            </nu:CardElement.ContentElement>
                        </nu:CardElement>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <nu:CardElement x:Name="SectionTriggerAreas" Margin="0,0,0,20">
                            <nu:CardElement.HeaderElement>
                                <Grid Margin="30,28,30,0">
                                    <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="触发区域" />
                                </Grid>
                            </nu:CardElement.HeaderElement>
                            <nu:CardElement.ContentElement>
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="通过 TriggerAreas 可以决定主标题区、箭头区和额外区哪些位置允许触发展开收起。" />
                                    <nc:NCollapse Width="420" TriggerAreas="Main, Arrow, Extra">
                                        <nc:NCollapseItem Title="全部区域都可触发" CollapseName="trigger-main">
                                            <nc:NCollapseItem.HeaderExtra>
                                                <Border Style="{StaticResource CollapseBadgeStyle}">
                                                    <TextBlock Foreground="#2E7D32" Text="点我也会切换" />
                                                </Border>
                                            </nc:NCollapseItem.HeaderExtra>
                                            <TextBlock TextWrapping="Wrap">当 TriggerAreas 包含 Extra 时，头部右侧额外内容区域也会参与展开收起。</TextBlock>
                                        </nc:NCollapseItem>
                                        <nc:NCollapseItem Title="保留主标题与箭头" CollapseName="trigger-arrow">
                                            <TextBlock TextWrapping="Wrap">默认配置通常使用 Main 与 Arrow 两个区域，既清晰也符合用户直觉。</TextBlock>
                                        </nc:NCollapseItem>
                                    </nc:NCollapse>
                                </StackPanel>
                            </nu:CardElement.ContentElement>
                        </nu:CardElement>

                        <nu:CardElement x:Name="SectionHeaderExtra" Margin="0,0,0,20">
                            <nu:CardElement.HeaderElement>
                                <Grid Margin="30,28,30,0">
                                    <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="额外内容与自定义头部" />
                                </Grid>
                            </nu:CardElement.HeaderElement>
                            <nu:CardElement.ContentElement>
                                <StackPanel Margin="30,24,30,24">
                                    <nc:NCollapse Width="420">
                                        <nc:NCollapseItem Title="头部右侧额外操作" CollapseName="extra">
                                            <nc:NCollapseItem.HeaderExtra>
                                                <nc:NButton Style="{StaticResource CollapseExtraButtonStyle}">更多</nc:NButton>
                                            </nc:NCollapseItem.HeaderExtra>
                                            <TextBlock TextWrapping="Wrap">HeaderExtra 适合放置状态说明、次级按钮或辅助提示。</TextBlock>
                                        </nc:NCollapseItem>
                                        <nc:NCollapseItem CollapseName="custom-header">
                                            <nc:NCollapseItem.Header>
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="15"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                                                        Text="自定义头部组合" />
                                                    <TextBlock
                                                        Margin="0,4,0,0"
                                                        Foreground="{DynamicResource Theme.Text.Tertiary.Brush}"
                                                        Text="可在头部中组合副标题、标签或状态摘要。" />
                                                </StackPanel>
                                            </nc:NCollapseItem.Header>
                                            <TextBlock TextWrapping="Wrap">当简单标题不足以表达上下文时，可以使用 Header 插槽自定义整块头部内容。</TextBlock>
                                        </nc:NCollapseItem>
                                    </nc:NCollapse>
                                </StackPanel>
                            </nu:CardElement.ContentElement>
                        </nu:CardElement>

                        <nu:CardElement x:Name="SectionDisabled" Margin="0,0,0,20">
                            <nu:CardElement.HeaderElement>
                                <Grid Margin="30,28,30,0">
                                    <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="禁用项" />
                                </Grid>
                            </nu:CardElement.HeaderElement>
                            <nu:CardElement.ContentElement>
                                <StackPanel Margin="30,24,30,24">
                                    <nc:NCollapse Width="420">
                                        <nc:NCollapseItem Title="可交互项" CollapseName="enabled">
                                            <TextBlock TextWrapping="Wrap">正常状态下的折叠项支持点击主区域和箭头区域切换。</TextBlock>
                                        </nc:NCollapseItem>
                                        <nc:NCollapseItem
                                            Title="禁用项"
                                            CollapseName="disabled"
                                            Disabled="True">
                                            <TextBlock TextWrapping="Wrap">禁用项不会响应展开收起，适合权限受限或暂不可用的内容块。</TextBlock>
                                        </nc:NCollapseItem>
                                    </nc:NCollapse>
                                </StackPanel>
                            </nu:CardElement.ContentElement>
                        </nu:CardElement>

                        <nu:CardElement x:Name="SectionDisplayDirective" Margin="0,0,0,20">
                            <nu:CardElement.HeaderElement>
                                <Grid Margin="30,28,30,0">
                                    <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="显示策略" />
                                </Grid>
                            </nu:CardElement.HeaderElement>
                            <nu:CardElement.ContentElement>
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="DisplayDirective 用来决定内容折叠后是直接移出视觉树，还是保留内容并仅收起高度。" />
                                    <nc:NCollapse Width="420" DisplayDirective="Show">
                                        <nc:NCollapseItem Title="继承父级 Show 策略" CollapseName="show">
                                            <TextBlock TextWrapping="Wrap">Show 适合需要保留内部状态或避免反复创建内容的区域。</TextBlock>
                                        </nc:NCollapseItem>
                                        <nc:NCollapseItem
                                            Title="单项覆盖为 If"
                                            CollapseName="if"
                                            DisplayDirective="If">
                                            <TextBlock TextWrapping="Wrap">当前项单独使用 If，表示折叠后直接从视觉树中移除内容。</TextBlock>
                                        </nc:NCollapseItem>
                                    </nc:NCollapse>
                                </StackPanel>
                            </nu:CardElement.ContentElement>
                        </nu:CardElement>
                    </StackPanel>
                </Grid>

                <nu:CardElement x:Name="SectionApi" Margin="0,20,0,20">
                    <nu:CardElement.HeaderElement>
                        <Grid Margin="30,28,30,0">
                            <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="API" />
                        </Grid>
                    </nu:CardElement.HeaderElement>
                    <nu:CardElement.ContentElement>
                        <TextBlock
                            Margin="30,24,30,24"
                            Style="{StaticResource DocBodyTextStyle}"
                            Text="下面的 API 表按当前 WPF Collapse 实现整理，分别列出父级容器和折叠项支持的属性与插槽。" />
                    </nu:CardElement.ContentElement>
                </nu:CardElement>

                <nu:CardElement x:Name="SectionCollapseProps" Margin="0,0,0,20">
                    <nu:CardElement.HeaderElement>
                        <Grid Margin="30,28,30,0">
                            <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="Collapse Props" />
                        </Grid>
                    </nu:CardElement.HeaderElement>
                    <nu:CardElement.ContentElement>
                        <sections:ApiDocTable Margin="30,24,30,24" ItemsSource="{Binding CollapsePropsRows}" />
                    </nu:CardElement.ContentElement>
                </nu:CardElement>

                <nu:CardElement x:Name="SectionCollapseItemProps" Margin="0,0,0,20">
                    <nu:CardElement.HeaderElement>
                        <Grid Margin="30,28,30,0">
                            <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="CollapseItem Props" />
                        </Grid>
                    </nu:CardElement.HeaderElement>
                    <nu:CardElement.ContentElement>
                        <sections:ApiDocTable Margin="30,24,30,24" ItemsSource="{Binding CollapseItemPropsRows}" />
                    </nu:CardElement.ContentElement>
                </nu:CardElement>

                <nu:CardElement x:Name="SectionCollapseSlots" Margin="0,0,0,20">
                    <nu:CardElement.HeaderElement>
                        <Grid Margin="30,28,30,0">
                            <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="Collapse Slots" />
                        </Grid>
                    </nu:CardElement.HeaderElement>
                    <nu:CardElement.ContentElement>
                        <sections:ApiDocTable Margin="30,24,30,24" ItemsSource="{Binding CollapseSlotsRows}" />
                    </nu:CardElement.ContentElement>
                </nu:CardElement>

                <nu:CardElement x:Name="SectionCollapseItemSlots" Margin="0,0,0,20">
                    <nu:CardElement.HeaderElement>
                        <Grid Margin="30,28,30,0">
                            <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="CollapseItem Slots" />
                        </Grid>
                    </nu:CardElement.HeaderElement>
                    <nu:CardElement.ContentElement>
                        <sections:ApiDocTable Margin="30,24,30,24" ItemsSource="{Binding CollapseItemSlotsRows}" />
                    </nu:CardElement.ContentElement>
                </nu:CardElement>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Column="2" Background="{DynamicResource Theme.Surface.0.Brush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20,36,20,20">
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="基础"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionBasic" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="手风琴模式"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionAccordion" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="默认展开项"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionDefaultExpanded" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="箭头位置"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionArrowPlacement" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="触发区域"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionTriggerAreas" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="额外内容与自定义头部"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionHeaderExtra" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="禁用项"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionDisabled" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="显示策略"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionDisplayDirective" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="接口说明"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionApi" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="折叠面板属性"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionCollapseProps" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="折叠项属性"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionCollapseItemProps" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="折叠面板插槽"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionCollapseSlots" />
                    <nc:NButton
                        Margin="3"
                        Click="ScrollToSection"
                        Content="折叠项插槽"
                        Kind="Tertiary"
                        Style="{StaticResource OutlineLinkButtonStyle}"
                        Tag="SectionCollapseItemSlots" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>

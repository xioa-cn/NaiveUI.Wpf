    <UserControl.Resources>
        <Style
            x:Key="SectionCardHeaderTitleStyle"
            BasedOn="{StaticResource DocSectionTitleStyle}"
            TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
        </Style>

        <Style x:Key="IconFilledPathStyle" TargetType="Path">
            <Setter Property="Fill"
                    Value="{Binding ResolvedBrush, RelativeSource={RelativeSource AncestorType={x:Type nc:NIcon}}}" />
            <Setter Property="Stretch" Value="Uniform" />
        </Style>

        <Style x:Key="IconStrokePathStyle" TargetType="Path">
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="Stroke"
                    Value="{Binding ResolvedBrush, RelativeSource={RelativeSource AncestorType={x:Type nc:NIcon}}}" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeThickness" Value="32" />
        </Style>

        <Style x:Key="IconStrokeLineStyle" TargetType="Line">
            <Setter Property="Stroke"
                    Value="{Binding ResolvedBrush, RelativeSource={RelativeSource AncestorType={x:Type nc:NIcon}}}" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeThickness" Value="32" />
        </Style>

        <Style x:Key="IconFilledEllipseStyle" TargetType="Ellipse">
            <Setter Property="Fill"
                    Value="{Binding ResolvedBrush, RelativeSource={RelativeSource AncestorType={x:Type nc:NIcon}}}" />
        </Style>

        <Style x:Key="IconStrokeEllipseStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="Stroke"
                    Value="{Binding ResolvedBrush, RelativeSource={RelativeSource AncestorType={x:Type nc:NIcon}}}" />
            <Setter Property="StrokeEndLineCap" Value="Round" />
            <Setter Property="StrokeStartLineCap" Value="Round" />
            <Setter Property="StrokeThickness" Value="32" />
        </Style>

        <Style x:Key="IconStrokeRectangleStyle" TargetType="Rectangle">
            <Setter Property="Fill" Value="Transparent" />
            <Setter Property="Stroke"
                    Value="{Binding ResolvedBrush, RelativeSource={RelativeSource AncestorType={x:Type nc:NIcon}}}" />
            <Setter Property="StrokeLineJoin" Value="Round" />
            <Setter Property="StrokeThickness" Value="32" />
        </Style>


                                        Text="按钮的 type 分别为 default、tertiary、primary、info、success、warning 和 error。" />
                                    <WrapPanel>
                                        <nc:NButton Margin="0,0,14,14">Default</nc:NButton>
                                        <nc:NButton Margin="0,0,14,14" Kind="Tertiary">Tertiary</nc:NButton>
                                        <nc:NButton Margin="0,0,14,14" Grade="Primary">Primary</nc:NButton>
                                        <nc:NButton Margin="0,0,14,14" Grade="Info">Info</nc:NButton>
                                        <nc:NButton Margin="0,0,14,14" Grade="Success">Success</nc:NButton>
                                        <nc:NButton Margin="0,0,14,14" Grade="Warning">Warning</nc:NButton>
                                        <nc:NButton Margin="0,0,14,14" Grade="Error">Error</nc:NButton>

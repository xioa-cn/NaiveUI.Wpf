<UserControl
    x:Class="NaiveUI.Demo.Views.Pages.LoadingBarDocsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:nc="clr-namespace:NaiveUI.NControls.Controls;assembly=NaiveUI.NControls"
    xmlns:nu="clr-namespace:NaiveUI.NControls.ControlsExample;assembly=NaiveUI.NControls"
    xmlns:sections="clr-namespace:NaiveUI.Demo.Views.Sections"
    xmlns:showMeTheXaml="clr-namespace:ShowMeTheXAML;assembly=ShowMeTheXAML"
    xmlns:viewModels="clr-namespace:NaiveUI.Demo.ViewModels"
    d:DataContext="{d:DesignInstance Type=viewModels:LoadingBarDocsPageViewModel}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style
            x:Key="SectionCardHeaderTitleStyle"
            BasedOn="{StaticResource DocSectionTitleStyle}"
            TargetType="TextBlock">
            <Setter Property="FontSize" Value="18" />
        </Style>

        <Style
            x:Key="DemoActionButtonStyle"
            BasedOn="{StaticResource NButtonBaseStyle}"
            TargetType="{x:Type nc:NButton}">
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="Kind" Value="Secondary" />
        </Style>

        <Style x:Key="ProviderPreviewStyle" TargetType="Border">
            <Setter Property="Height" Value="180" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Background" Value="{DynamicResource Theme.Surface.1.Brush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border.Brush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource Theme.Surface.0.Brush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="220" />
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="25,34,18,34">
                <TextBlock
                    FontSize="48"
                    FontWeight="Bold"
                    Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                    Text="加载条 Loading Bar" />

                <TextBlock
                    Margin="0,26,0,0"
                    FontSize="18"
                    Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                    Text="全局顶部加载条。围绕 Naive UI Loading Bar 的 start / finish / error / provider 语义实现，并尽量贴近其速度感与光泽效果。" />

                <TextBlock
                    Margin="0,52,0,28"
                    FontSize="36"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                    Text="演示" />

                <StackPanel>
                    <nu:CardElement x:Name="SectionBasic" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="基础用法" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <showMeTheXaml:XamlDisplay Style="{StaticResource AvalonEditXamlDisplay}" UniqueKey="LoadingBarDocsPage1">
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="最基础的全局 loading bar 调用方式。默认会在主窗口顶部显示，并自动做 trickle 动画。" />
                                    <WrapPanel>
                                        <nc:NButton
                                            Command="{Binding LoadingBarCommand}"
                                            CommandParameter="start"
                                            Grade="Default"
                                            Style="{StaticResource DemoActionButtonStyle}">
                                            开始
                                        </nc:NButton>
                                        <nc:NButton
                                            Command="{Binding LoadingBarCommand}"
                                            CommandParameter="manual-30"
                                            Grade="Info"
                                            Style="{StaticResource DemoActionButtonStyle}">
                                            设置 30%
                                        </nc:NButton>
                                        <nc:NButton
                                            Command="{Binding LoadingBarCommand}"
                                            CommandParameter="manual-70"
                                            Grade="Info"
                                            Style="{StaticResource DemoActionButtonStyle}">
                                            设置 70%
                                        </nc:NButton>
                                        <nc:NButton
                                            Command="{Binding LoadingBarCommand}"
                                            CommandParameter="finish"
                                            Grade="Success"
                                            Style="{StaticResource DemoActionButtonStyle}">
                                            完成
                                        </nc:NButton>
                                        <nc:NButton
                                            Command="{Binding LoadingBarCommand}"
                                            CommandParameter="error"
                                            Grade="Error"
                                            Style="{StaticResource DemoActionButtonStyle}">
                                            错误
                                        </nc:NButton>
                                    </WrapPanel>
                                </StackPanel>
                            </showMeTheXaml:XamlDisplay>
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionThickness" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="粗细" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <showMeTheXaml:XamlDisplay Style="{StaticResource AvalonEditXamlDisplay}" UniqueKey="LoadingBarDocsPageThickness">
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,18"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="通过 NLoadingBarProvider.BarHeight 可以调节加载条粗细。下面这个局部 provider 把粗细提高到了 6px，用来和默认样式做直观对比。" />
                                    <nc:NLoadingBarProvider x:Name="ThickLoadingBarProvider" BarHeight="6">
                                        <Border Style="{StaticResource ProviderPreviewStyle}">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock
                                                    Margin="0,0,0,12"
                                                    Style="{StaticResource DocBodyTextStyle}"
                                                    Text="点击下面按钮后，这个区域顶部会显示一条更粗的 6px loading bar。" />
                                                <WrapPanel>
                                                    <nc:NButton
                                                        Click="HandleThickLoadingBarStartClick"
                                                        Grade="Info"
                                                        Style="{StaticResource DemoActionButtonStyle}">
                                                        启动 6px
                                                    </nc:NButton>
                                                    <nc:NButton
                                                        Click="HandleThickLoadingBarFinishClick"
                                                        Grade="Success"
                                                        Style="{StaticResource DemoActionButtonStyle}">
                                                        完成 6px
                                                    </nc:NButton>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </nc:NLoadingBarProvider>
                                </StackPanel>
                            </showMeTheXaml:XamlDisplay>
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionStateFlow" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="状态流转" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <showMeTheXaml:XamlDisplay Style="{StaticResource AvalonEditXamlDisplay}" UniqueKey="LoadingBarDocsPage2">
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,20"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="最常见的是在异步流程前 start，在成功时 finish，在失败时 error。下面两个按钮会模拟完整的请求生命周期。" />
                                    <WrapPanel>
                                        <nc:NButton
                                            Command="{Binding LoadingBarCommand}"
                                            CommandParameter="sequence"
                                            Grade="Primary"
                                            Style="{StaticResource DemoActionButtonStyle}">
                                            成功流程
                                        </nc:NButton>
                                        <nc:NButton
                                            Command="{Binding LoadingBarCommand}"
                                            CommandParameter="error-sequence"
                                            Grade="Error"
                                            Style="{StaticResource DemoActionButtonStyle}">
                                            失败流程
                                        </nc:NButton>
                                    </WrapPanel>
                                </StackPanel>
                            </showMeTheXaml:XamlDisplay>
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionProvider" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="Provider" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <showMeTheXaml:XamlDisplay Style="{StaticResource AvalonEditXamlDisplay}" UniqueKey="LoadingBarDocsPage3">
                                <StackPanel Margin="30,24,30,24">
                                    <TextBlock
                                        Margin="0,0,0,18"
                                        Style="{StaticResource DocBodyTextStyle}"
                                        Text="和 MessageProvider 一样，LoadingBar 也支持局部 provider。下面这个区域会把 loading bar 限定在自己的顶部，而不是主窗口顶部。" />
                                    <nc:NLoadingBarProvider x:Name="LocalLoadingBarProvider">
                                        <Border Style="{StaticResource ProviderPreviewStyle}">
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock
                                                    Margin="0,0,0,12"
                                                    Style="{StaticResource DocBodyTextStyle}"
                                                    Text="点击按钮后，局部 loading bar 会显示在这个卡片顶部。" />
                                                <WrapPanel>
                                                    <nc:NButton
                                                        Click="HandleScopedLoadingBarStartClick"
                                                        Grade="Info"
                                                        Style="{StaticResource DemoActionButtonStyle}">
                                                        局部开始
                                                    </nc:NButton>
                                                    <nc:NButton
                                                        Click="HandleScopedLoadingBarFinishClick"
                                                        Grade="Success"
                                                        Style="{StaticResource DemoActionButtonStyle}">
                                                        局部完成
                                                    </nc:NButton>
                                                    <nc:NButton
                                                        Click="HandleScopedLoadingBarErrorClick"
                                                        Grade="Error"
                                                        Style="{StaticResource DemoActionButtonStyle}">
                                                        局部错误
                                                    </nc:NButton>
                                                </WrapPanel>
                                            </StackPanel>
                                        </Border>
                                    </nc:NLoadingBarProvider>
                                </StackPanel>
                            </showMeTheXaml:XamlDisplay>
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionApi" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="API" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <TextBlock
                                Margin="30,24,30,24"
                                Style="{StaticResource DocBodyTextStyle}"
                                Text="当前 WPF 版本实现了 Naive UI Loading Bar 最核心的全局反馈链路：start、update、finish、error，以及全局 / 局部 provider 作用域。" />
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>

                    <nu:CardElement x:Name="SectionLoadingBarApi" Margin="0,0,0,20">
                        <nu:CardElement.HeaderElement>
                            <Grid Margin="30,28,30,0">
                                <TextBlock Style="{StaticResource SectionCardHeaderTitleStyle}" Text="LoadingBar API" />
                            </Grid>
                        </nu:CardElement.HeaderElement>
                        <nu:CardElement.ContentElement>
                            <sections:ApiDocTable Margin="30,24,30,24" ItemsSource="{Binding LoadingBarApiRows}" />
                        </nu:CardElement.ContentElement>
                    </nu:CardElement>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Column="1" Background="{DynamicResource Theme.Surface.0.Brush}">
            <nc:NMenu
                Margin="20,36,20,20"
                DisplayMemberPath="Label"
                ItemInvoked="HandleOutlineItemInvoked"
                ItemsSource="{Binding OutlineItems}"
                SelectedValuePath="TargetName" />
        </Border>
    </Grid>
</UserControl>

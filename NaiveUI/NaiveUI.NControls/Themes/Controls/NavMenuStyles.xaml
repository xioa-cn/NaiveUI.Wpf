<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:NaiveUI.NControls.Controls">

    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <Style x:Key="NNavMenuGroupHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="0,0,0,18" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Tertiary.Brush}" />
    </Style>

    <Style x:Key="NNavMenuItemButtonStyle" TargetType="Button">
        <Setter Property="Margin" Value="10,0,0,8" />
        <Setter Property="Padding" Value="18,0" />
        <Setter Property="Height" Value="50" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border
                        x:Name="RootBorder"
                        Background="{TemplateBinding Background}"
                        CornerRadius="6">
                        <ContentPresenter
                            Margin="5"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource Theme.Fill.Hover.Brush}" />
                        </Trigger>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter TargetName="RootBorder" Property="Background" Value="{DynamicResource Primary.Third.Brush}" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NNavMenuItemTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary.Brush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding DataContext.IsSelected, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource Primary.First.Brush}" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="NNavMenuItemSubtitleTextStyle" TargetType="TextBlock">
        <Setter Property="Margin" Value="4,0,0,0" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Tertiary.Brush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Style.Triggers>
            <DataTrigger Binding="{Binding DataContext.IsSelected, RelativeSource={RelativeSource AncestorType=Button}}" Value="True">
                <Setter Property="Foreground" Value="{DynamicResource Primary.First.Brush}" />
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="NNavMenuBaseStyle" TargetType="{x:Type controls:NNavMenu}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="ItemTemplate">
            <Setter.Value>
                <DataTemplate>
                    <StackPanel Margin="0,0,0,18">
                        <TextBlock Style="{StaticResource NNavMenuGroupHeaderTextStyle}" Text="{Binding HeaderText}" />
                        <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource NNavMenuItemButtonStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Style="{StaticResource NNavMenuItemTitleTextStyle}" Text="{Binding Title}" />
                                                <TextBlock Style="{StaticResource NNavMenuItemSubtitleTextStyle}" Text="{Binding Subtitle}" />
                                            </StackPanel>
                                            <Border
                                                Grid.Column="1"
                                                Margin="10,0,0,0"
                                                Padding="7,1"
                                                VerticalAlignment="Center"
                                                Background="#E6F9F0"
                                                CornerRadius="11"
                                                Visibility="{Binding HasBadge, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock
                                                    FontSize="12"
                                                    Foreground="#18A058"
                                                    Text="{Binding BadgeText}" />
                                            </Border>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NNavMenu}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <controls:NScrollViewer Focusable="False" VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter />
                        </controls:NScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style BasedOn="{StaticResource NNavMenuBaseStyle}" TargetType="{x:Type controls:NNavMenu}"/>
</ResourceDictionary>

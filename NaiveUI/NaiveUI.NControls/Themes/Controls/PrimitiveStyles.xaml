<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:NaiveUI.NControls.Controls">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/NaiveUI.NControls;component/Themes/ThemeTokens.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="{x:Type controls:NDivider}">
        <Setter Property="Margin" Value="0,8" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Tertiary.Brush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NDivider}">
                    <Grid>
                        <Grid x:Name="HorizontalRoot">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border
                                x:Name="StartLine"
                                Grid.Column="0"
                                Height="1"
                                VerticalAlignment="Center"
                                Background="{DynamicResource Theme.Border.Brush}" />
                            <ContentPresenter
                                x:Name="TitlePresenter"
                                Grid.Column="1"
                                Margin="12,0"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding Title}"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                            <Border
                                x:Name="EndLine"
                                Grid.Column="2"
                                Height="1"
                                VerticalAlignment="Center"
                                Background="{DynamicResource Theme.Border.Brush}" />
                        </Grid>
                        <Border
                            x:Name="VerticalRoot"
                            Width="1"
                            HorizontalAlignment="Center"
                            Background="{DynamicResource Theme.Border.Brush}"
                            Visibility="Collapsed" />
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Title" Value="{x:Null}">
                            <Setter TargetName="TitlePresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="StartLine" Property="Grid.ColumnSpan" Value="3" />
                            <Setter TargetName="EndLine" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="Orientation" Value="Vertical">
                            <Setter TargetName="HorizontalRoot" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="VerticalRoot" Property="Visibility" Value="Visible" />
                            <Setter Property="Width" Value="1" />
                            <Setter Property="MinHeight" Value="1" />
                        </Trigger>
                        <Trigger Property="TitlePlacement" Value="Start">
                            <Setter TargetName="StartLine" Property="Width" Value="28" />
                        </Trigger>
                        <Trigger Property="TitlePlacement" Value="End">
                            <Setter TargetName="EndLine" Property="Width" Value="28" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NIcon}">
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="20" />
        <Setter Property="IconBrush" Value="{DynamicResource Theme.Text.Secondary.Brush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NIcon}">
                    <Viewbox StretchDirection="Both">
                        <Path
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            Data="{TemplateBinding Data}"
                            Fill="{TemplateBinding IconBrush}"
                            Stretch="{TemplateBinding Stretch}" />
                    </Viewbox>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NLayout}">
        <Setter Property="Background" Value="{DynamicResource Theme.Window.Background.Brush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NLayout}">
                    <Border Background="{TemplateBinding Background}">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NLayoutHeader}">
        <Setter Property="Padding" Value="24,16" />
        <Setter Property="Background" Value="{DynamicResource Theme.Surface.0.Brush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NLayoutHeader}">
                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NLayoutContent}">
        <Setter Property="Padding" Value="24" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NLayoutContent}">
                    <Border Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NLayoutFooter}">
        <Setter Property="Padding" Value="24,16" />
        <Setter Property="Background" Value="{DynamicResource Theme.Surface.0.Brush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NLayoutFooter}">
                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NScrollbar}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NScrollbar}">
                    <Grid Background="{TemplateBinding Background}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <ScrollContentPresenter Grid.Row="0" Grid.Column="0" CanContentScroll="{TemplateBinding CanContentScroll}" />
                        <ScrollBar
                            x:Name="PART_VerticalScrollBar"
                            Grid.Row="0"
                            Grid.Column="1"
                            Width="10"
                            Margin="2,0,0,0"
                            Opacity="0.7"
                            Orientation="Vertical"
                            Value="{Binding VerticalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                            Maximum="{TemplateBinding ScrollableHeight}"
                            ViewportSize="{TemplateBinding ViewportHeight}"
                            Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
                        <ScrollBar
                            x:Name="PART_HorizontalScrollBar"
                            Grid.Row="1"
                            Grid.Column="0"
                            Height="10"
                            Margin="0,2,0,0"
                            Opacity="0.7"
                            Orientation="Horizontal"
                            Value="{Binding HorizontalOffset, RelativeSource={RelativeSource TemplatedParent}, Mode=OneWay}"
                            Maximum="{TemplateBinding ScrollableWidth}"
                            ViewportSize="{TemplateBinding ViewportWidth}"
                            Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="10" />
        <Setter Property="Height" Value="10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="False">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Background="Transparent" BorderThickness="0" IsTabStop="False" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border
                                                Margin="2"
                                                Background="{DynamicResource Theme.Fill.2Pressed.Brush}"
                                                CornerRadius="{StaticResource Radius.Round}" />
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Background="Transparent" BorderThickness="0" IsTabStop="False" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

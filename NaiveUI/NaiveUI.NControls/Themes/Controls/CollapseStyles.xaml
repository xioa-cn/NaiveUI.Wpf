<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:NaiveUI.NControls.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/NaiveUI.NControls;component/Themes/ThemeTokens.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Geometry x:Key="Collapse.Chevron">M6.25 4.75C6.66421 4.33579 7.33579 4.33579 7.75 4.75L13.75 10.75C14.1642 11.1642 14.1642 11.8358 13.75 12.25L7.75 18.25C7.33579 18.6642 6.66421 18.6642 6.25 18.25C5.83579 17.8358 5.83579 17.1642 6.25 16.75L11.5 11.5L6.25 6.25C5.83579 5.83579 5.83579 5.16421 6.25 4.75Z</Geometry>

    <Style x:Key="Naive.Collapse.HitTargetStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="CornerRadius" Value="3" />
    </Style>

    <Style TargetType="{x:Type controls:NCollapse}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border.Brush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary.Brush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NCollapse}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <ItemsPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NCollapseItem}">
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary.Brush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NCollapseItem}">
                    <Border BorderBrush="{DynamicResource Theme.Border.Brush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    x:Name="PART_LeftArrowToggle"
                                    Grid.Column="0"
                                    Width="20"
                                    Height="20"
                                    Margin="0,14,8,14"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource Naive.Collapse.HitTargetStyle}">
                                    <Path
                                        Width="16"
                                        Height="16"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Data="{StaticResource Collapse.Chevron}"
                                        Fill="{DynamicResource Theme.Text.Secondary.Brush}"
                                        Stretch="Uniform">
                                        <Path.RenderTransform>
                                            <RotateTransform x:Name="PART_LeftArrowTransform" Angle="0" CenterX="8" CenterY="8" />
                                        </Path.RenderTransform>
                                    </Path>
                                </Border>

                                <Border
                                    x:Name="PART_MainToggle"
                                    Grid.Column="1"
                                    Margin="0"
                                    Padding="0,14,0,14"
                                    Style="{StaticResource Naive.Collapse.HitTargetStyle}">
                                    <Grid>
                                        <ContentPresenter
                                            x:Name="CustomHeaderPresenter"
                                            VerticalAlignment="Center"
                                            Content="{TemplateBinding Header}"
                                            ContentStringFormat="{TemplateBinding HeaderStringFormat}"
                                            ContentTemplate="{TemplateBinding HeaderTemplate}"
                                            ContentTemplateSelector="{TemplateBinding HeaderTemplateSelector}"
                                            TextElement.Foreground="{TemplateBinding Foreground}"
                                            Visibility="Collapsed" />
                                        <TextBlock
                                            x:Name="TitlePresenter"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Foreground="{TemplateBinding Foreground}"
                                            Text="{TemplateBinding Title}"
                                            TextWrapping="Wrap"
                                            Visibility="Collapsed" />
                                    </Grid>
                                </Border>

                                <Border
                                    x:Name="PART_ExtraToggle"
                                    Grid.Column="2"
                                    Margin="12,0,0,0"
                                    Padding="0,8,0,8"
                                    VerticalAlignment="Center"
                                    Background="Transparent">
                                    <ContentPresenter
                                        x:Name="HeaderExtraPresenter"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding HeaderExtra}" />
                                </Border>

                                <Border
                                    x:Name="PART_RightArrowToggle"
                                    Grid.Column="3"
                                    Width="20"
                                    Height="20"
                                    Margin="12,14,0,14"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource Naive.Collapse.HitTargetStyle}"
                                    Visibility="Collapsed">
                                    <Path
                                        Width="16"
                                        Height="16"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Data="{StaticResource Collapse.Chevron}"
                                        Fill="{DynamicResource Theme.Text.Secondary.Brush}"
                                        Stretch="Uniform">
                                        <Path.RenderTransform>
                                            <RotateTransform x:Name="PART_RightArrowTransform" Angle="0" CenterX="8" CenterY="8" />
                                        </Path.RenderTransform>
                                    </Path>
                                </Border>
                            </Grid>

                            <Border
                                x:Name="PART_ContentContainer"
                                Grid.Row="1"
                                Height="0"
                                ClipToBounds="True"
                                Opacity="0"
                                Visibility="Collapsed">
                                <ContentPresenter
                                    x:Name="PART_ContentPresenter"
                                    Margin="{TemplateBinding ResolvedContentPadding}"
                                    Content="{TemplateBinding PresentedContent}"
                                    ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                    ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                    TextElement.Foreground="{DynamicResource Theme.Text.Secondary.Brush}" />
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasCustomHeader" Value="True">
                            <Setter TargetName="CustomHeaderPresenter" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasTitle" Value="True">
                            <Setter TargetName="TitlePresenter" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasHeaderExtra" Value="False">
                            <Setter TargetName="PART_ExtraToggle" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="ResolvedArrowPlacement" Value="Right">
                            <Setter TargetName="PART_LeftArrowToggle" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_RightArrowToggle" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Disabled" Value="True">
                            <Setter TargetName="TitlePresenter" Property="Foreground" Value="{DynamicResource Theme.Text.Tertiary.Brush}" />
                            <Setter TargetName="PART_MainToggle" Property="Cursor" Value="Arrow" />
                            <Setter TargetName="PART_LeftArrowToggle" Property="Cursor" Value="Arrow" />
                            <Setter TargetName="PART_RightArrowToggle" Property="Cursor" Value="Arrow" />
                            <Setter TargetName="PART_MainToggle" Property="Opacity" Value="0.6" />
                            <Setter TargetName="PART_ExtraToggle" Property="Opacity" Value="0.6" />
                            <Setter TargetName="PART_LeftArrowToggle" Property="Opacity" Value="0.45" />
                            <Setter TargetName="PART_RightArrowToggle" Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

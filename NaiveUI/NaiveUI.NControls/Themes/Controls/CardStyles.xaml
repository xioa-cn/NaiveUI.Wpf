<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:card="clr-namespace:NaiveUI.NControls.ControlsExample"
    xmlns:controls="clr-namespace:NaiveUI.NControls.Controls">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/NaiveUI.NControls;component/Themes/ThemeTokens.xaml" />

    </ResourceDictionary.MergedDictionaries>
    <Storyboard x:Key="SkeletonAnimation" RepeatBehavior="Forever">
        <DoubleAnimation
            AutoReverse="True"
            RepeatBehavior="Forever"
            Storyboard.TargetName="headerSkeleton"
            Storyboard.TargetProperty="Opacity"
            From="0.45"
            To="1"
            Duration="0:0:0.9" />
        <DoubleAnimation
            AutoReverse="True"
            RepeatBehavior="Forever"
            Storyboard.TargetName="contentSkeleton"
            Storyboard.TargetProperty="Opacity"
            From="0.45"
            To="1"
            Duration="0:0:0.9" />
    </Storyboard>

    <Style TargetType="{x:Type controls:NCard}">
        <Setter Property="Background" Value="{DynamicResource Theme.Surface.0.Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary.Brush}" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NCard}">
                    <Border
                        x:Name="PART_RootBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid
                                x:Name="HeaderContainer"
                                Grid.Row="0"
                                Margin="{TemplateBinding ResolvedHeaderPadding}"
                                Visibility="Collapsed">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter
                                    x:Name="CustomHeaderPresenter"
                                    Content="{TemplateBinding Header}"
                                    Visibility="Collapsed" />

                                <TextBlock
                                    x:Name="TitlePresenter"
                                    FontSize="{TemplateBinding ResolvedTitleFontSize}"
                                    FontWeight="SemiBold"
                                    Foreground="{TemplateBinding Foreground}"
                                    Text="{TemplateBinding Title}"
                                    TextWrapping="Wrap"
                                    Visibility="Collapsed" />

                                <ContentPresenter
                                    x:Name="HeaderExtraPresenter"
                                    Grid.Column="1"
                                    Margin="16,0,0,0"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding HeaderExtra}"
                                    Visibility="Collapsed" />
                            </Grid>

                            <Border
                                x:Name="HeaderSeparator"
                                Grid.Row="1"
                                Height="1"
                                Margin="0,16,0,0"
                                Background="{DynamicResource Theme.Border.Brush}"
                                Visibility="Collapsed" />

                            <Border
                                x:Name="CoverContainer"
                                Grid.Row="2"
                                Background="Transparent"
                                ClipToBounds="True"
                                Visibility="Collapsed">
                                <ContentPresenter x:Name="CoverPresenter" Content="{TemplateBinding Cover}" />
                            </Border>

                            <ContentPresenter
                                x:Name="ContentPresenter"
                                Grid.Row="3"
                                Margin="{TemplateBinding ResolvedContentPadding}"
                                Content="{TemplateBinding Content}" />

                            <Border
                                x:Name="ActionContainer"
                                Grid.Row="4"
                                Background="{DynamicResource Theme.Surface.1.Brush}"
                                Visibility="Collapsed">
                                <Border
                                    Background="Transparent"
                                    BorderBrush="{DynamicResource Theme.Border.Brush}"
                                    BorderThickness="0,1,0,0">
                                    <ContentPresenter Margin="{TemplateBinding ResolvedActionPadding}" Content="{TemplateBinding Action}" />
                                </Border>
                            </Border>

                            <Border
                                x:Name="FooterContainer"
                                Grid.Row="5"
                                Background="{DynamicResource Theme.Surface.1.Brush}"
                                Visibility="Collapsed">
                                <Border
                                    Background="Transparent"
                                    BorderBrush="{DynamicResource Theme.Border.Brush}"
                                    BorderThickness="0,1,0,0">
                                    <ContentPresenter Margin="{TemplateBinding ResolvedFooterPadding}" Content="{TemplateBinding Footer}" />
                                </Border>
                            </Border>

                            <Grid x:Name="LoadingMask" Visibility="Collapsed">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border
                                    x:Name="headerSkeleton"
                                    Grid.Row="0"
                                    Height="22"
                                    Margin="24,20,140,0"
                                    Background="{DynamicResource Theme.Fill.2.Brush}"
                                    CornerRadius="{StaticResource Radius.Small}"
                                    Opacity="0.45"
                                    Visibility="Collapsed" />

                                <Rectangle
                                    x:Name="coverSkeleton"
                                    Grid.Row="1"
                                    Height="160"
                                    Margin="0,18,0,0"
                                    Fill="{DynamicResource Theme.Fill.2.Brush}"
                                    Opacity="0.45"
                                    Visibility="Collapsed" />

                                <StackPanel
                                    x:Name="contentSkeleton"
                                    Grid.Row="2"
                                    Margin="24"
                                    Opacity="0.45"
                                    Visibility="Collapsed">
                                    <Border
                                        Height="14"
                                        Margin="0,0,0,12"
                                        Background="{DynamicResource Theme.Fill.2.Brush}"
                                        CornerRadius="{StaticResource Radius.Small}" />
                                    <Border
                                        Height="14"
                                        Margin="0,0,0,12"
                                        Background="{DynamicResource Theme.Fill.2.Brush}"
                                        CornerRadius="{StaticResource Radius.Small}" />
                                    <Border
                                        Width="220"
                                        Height="14"
                                        HorizontalAlignment="Left"
                                        Background="{DynamicResource Theme.Fill.2.Brush}"
                                        CornerRadius="{StaticResource Radius.Small}" />
                                </StackPanel>

                                <Border
                                    x:Name="footerSkeleton"
                                    Grid.Row="3"
                                    Height="44"
                                    Margin="24,0,24,24"
                                    Background="{DynamicResource Theme.Fill.2.Brush}"
                                    CornerRadius="{StaticResource Radius.Small}"
                                    Opacity="0.45"
                                    Visibility="Collapsed" />
                            </Grid>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasHeader" Value="True">
                            <Setter TargetName="HeaderContainer" Property="Visibility" Value="Visible" />
                            <Setter TargetName="HeaderSeparator" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasCustomHeader" Value="True">
                            <Setter TargetName="CustomHeaderPresenter" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasTitle" Value="True">
                            <Setter TargetName="TitlePresenter" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasHeaderExtra" Value="True">
                            <Setter TargetName="HeaderExtraPresenter" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasCover" Value="True">
                            <Setter TargetName="CoverContainer" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasAction" Value="True">
                            <Setter TargetName="ActionContainer" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasFooter" Value="True">
                            <Setter TargetName="FooterContainer" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Bordered" Value="False">
                            <Setter TargetName="PART_RootBorder" Property="BorderBrush" Value="Transparent" />
                        </Trigger>
                        <Trigger Property="Embedded" Value="True">
                            <Setter TargetName="PART_RootBorder" Property="Background" Value="{DynamicResource Theme.Surface.1.Brush}" />
                        </Trigger>
                        <Trigger Property="Segmented" Value="True">
                            <Setter TargetName="ActionContainer" Property="Background" Value="{DynamicResource Theme.Surface.0.Brush}" />
                            <Setter TargetName="FooterContainer" Property="Background" Value="{DynamicResource Theme.Surface.0.Brush}" />
                        </Trigger>
                        <Trigger Property="IsLoading" Value="True">
                            <Setter TargetName="HeaderContainer" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="HeaderSeparator" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="CoverContainer" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ContentPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ActionContainer" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="FooterContainer" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="LoadingMask" Property="Visibility" Value="Visible" />
                            <Setter TargetName="headerSkeleton" Property="Visibility" Value="Visible" />
                            <Setter TargetName="contentSkeleton" Property="Visibility" Value="Visible" />
                            <Setter TargetName="footerSkeleton" Property="Visibility" Value="Visible" />
                            <Trigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource SkeletonAnimation}" />
                            </Trigger.EnterActions>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsLoading" Value="True" />
                                <Condition Property="HasCover" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="coverSkeleton" Property="Visibility" Value="Visible" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type card:CardElement}">
        <Setter Property="Background" Value="{DynamicResource Theme.Surface.0.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BoderColor" Value="{DynamicResource Theme.Border.Color}" />
        <Setter Property="FooterBackgroundBrush" Value="{DynamicResource Theme.Surface.1.Brush}" />
        <Setter Property="HoverableBackground" Value="{DynamicResource Theme.Surface.1.Brush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type card:CardElement}">
                    <Border
                        x:Name="cardBorder"
                        Background="{TemplateBinding Background}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{StaticResource Radius.Large}">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=BoderColor}" />
                        </Border.BorderBrush>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <ContentPresenter
                                x:Name="headerContent"
                                Grid.Row="0"
                                Margin="20,18,20,0"
                                Content="{TemplateBinding HeaderElement}"
                                Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=HeaderElement, Converter={StaticResource NullToVisibilityConverter}}" />
                            <Separator
                                x:Name="headerSeparator"
                                Grid.Row="1"
                                Margin="20,16,20,0"
                                Background="{DynamicResource Theme.Border.Brush}"
                                Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=HeaderElement, Converter={StaticResource NullToVisibilityConverter}}" />
                            <ContentPresenter
                                x:Name="mainContent"
                                Grid.Row="2"
                                Margin="20"
                                Content="{TemplateBinding ContentElement}" />
                            <Border
                                x:Name="footerContainer"
                                Grid.Row="3"
                                Background="{TemplateBinding FooterBackgroundBrush}"
                                CornerRadius="0,0,18,18"
                                Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=FooterElement, Converter={StaticResource NullToVisibilityConverter}}">
                                <ContentPresenter Margin="20,16" Content="{TemplateBinding FooterElement}" />
                            </Border>

                            <Border
                                x:Name="headerSkeleton"
                                Grid.Row="0"
                                Height="22"
                                Margin="20,18,120,0"
                                Background="{DynamicResource Theme.Fill.2.Brush}"
                                CornerRadius="{StaticResource Radius.Small}"
                                Opacity="0"
                                Visibility="Collapsed" />
                            <StackPanel
                                x:Name="contentSkeleton"
                                Grid.Row="2"
                                Margin="20"
                                Opacity="0"
                                Visibility="Collapsed">
                                <Border
                                    Height="14"
                                    Margin="0,0,0,12"
                                    Background="{DynamicResource Theme.Fill.2.Brush}"
                                    CornerRadius="{StaticResource Radius.Small}" />
                                <Border
                                    Height="14"
                                    Margin="0,0,0,12"
                                    Background="{DynamicResource Theme.Fill.2.Brush}"
                                    CornerRadius="{StaticResource Radius.Small}" />
                                <Border
                                    Width="220"
                                    Height="14"
                                    HorizontalAlignment="Left"
                                    Background="{DynamicResource Theme.Fill.2.Brush}"
                                    CornerRadius="{StaticResource Radius.Small}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="OpenBordered" Value="False">
                            <Setter TargetName="cardBorder" Property="BorderBrush" Value="Transparent" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="Hoverable" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <MultiTrigger.Setters>
                                <Setter TargetName="cardBorder" Property="BorderBrush" Value="{DynamicResource Theme.Border.Strong.Brush}" />
                            </MultiTrigger.Setters>
                        </MultiTrigger>
                        <Trigger Property="Skeleton" Value="Loading">
                            <Setter TargetName="headerContent" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="headerSeparator" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="mainContent" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="footerContainer" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="headerSkeleton" Property="Visibility" Value="Visible" />
                            <Setter TargetName="contentSkeleton" Property="Visibility" Value="Visible" />
                            <Trigger.EnterActions>
                                <BeginStoryboard Storyboard="{StaticResource SkeletonAnimation}" />
                            </Trigger.EnterActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

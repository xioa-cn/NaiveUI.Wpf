<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:NaiveUI.NControls.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/NaiveUI.NControls;component/Themes/ThemeTokens.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="{x:Type controls:NTooltip}">
        <Setter Property="Background" Value="{DynamicResource Theme.Tooltip.Background.Brush}" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Tooltip.Foreground.Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Tooltip.Border.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NTooltip}">
                    <Border Background="Transparent" SnapsToDevicePixels="True">
                        <ContentPresenter ContentSource="Content" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NTooltipPopup}">
        <Setter Property="Background" Value="{DynamicResource Theme.Tooltip.Background.Brush}" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Tooltip.Foreground.Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Tooltip.Border.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NTooltipPopup}">
                    <Grid Background="Transparent" SnapsToDevicePixels="True">
                        <Canvas IsHitTestVisible="False">
                            <Path
                                x:Name="Arrow"
                                Canvas.Left="{TemplateBinding ArrowLeft}"
                                Canvas.Top="{TemplateBinding ArrowTop}"
                                Width="{TemplateBinding ArrowWidth}"
                                Height="{TemplateBinding ArrowHeight}"
                                Data="{TemplateBinding ArrowData}"
                                Fill="{TemplateBinding Background}"
                                RenderTransformOrigin="0.5,0.5"
                                Stretch="Fill"
                                Visibility="Collapsed">
                            </Path>
                        </Canvas>

                        <Border
                            x:Name="Host"
                            Margin="{TemplateBinding PopupContentMargin}"
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="18"
                                    Color="#111827"
                                    Opacity="0.18"
                                    ShadowDepth="4" />
                            </Border.Effect>
                            <ContentPresenter
                                ContentSource="Content"
                                RecognizesAccessKey="True"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowArrowVisual" Value="True">
                            <Setter TargetName="Arrow" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <Trigger Property="Raw" Value="True">
                            <Setter TargetName="Arrow" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="Host" Property="Background" Value="Transparent" />
                            <Setter TargetName="Host" Property="BorderBrush" Value="{x:Null}" />
                            <Setter TargetName="Host" Property="BorderThickness" Value="0" />
                            <Setter TargetName="Host" Property="Padding" Value="0" />
                            <Setter TargetName="Host" Property="Effect" Value="{x:Null}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

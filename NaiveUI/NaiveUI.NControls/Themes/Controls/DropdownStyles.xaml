<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:NaiveUI.NControls.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/NaiveUI.NControls;component/Themes/ThemeTokens.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Geometry x:Key="Dropdown.SubmenuChevron">M6.25 4.75C6.66421 4.33579 7.33579 4.33579 7.75 4.75L13.75 10.75C14.1642 11.1642 14.1642 11.8358 13.75 12.25L7.75 18.25C7.33579 18.6642 6.66421 18.6642 6.25 18.25C5.83579 17.8358 5.83579 17.1642 6.25 16.75L11.5 11.5L6.25 6.25C5.83579 5.83579 5.83579 5.16421 6.25 4.75Z</Geometry>

    <Style x:Key="NDropdownBaseStyle" TargetType="{x:Type controls:NDropdown}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NDropdown}">
                    <Grid SnapsToDevicePixels="True">
                        <ContentPresenter ContentSource="Content" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style BasedOn="{StaticResource NDropdownBaseStyle}" TargetType="{x:Type controls:NDropdown}"/>

    <Style x:Key="{x:Static controls:NDropdownMenu.SeparatorStyleKey}" TargetType="{x:Type Separator}">
        <Setter Property="Margin" Value="8,4" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Separator}">
                    <Border Height="1" Background="{DynamicResource Theme.Border.Brush}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NDropdownMenuBaseStyle" TargetType="{x:Type controls:NDropdownMenu}">
        <Setter Property="Background" Value="{DynamicResource Theme.Surface.0.Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="HasDropShadow" Value="False" />
        <Setter Property="MinWidth" Value="144" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NDropdownMenu}">
                    <Grid Background="Transparent" SnapsToDevicePixels="True">
                        <Canvas IsHitTestVisible="False">
                            <Border
                                x:Name="Arrow"
                                Canvas.Left="{TemplateBinding ArrowLeft}"
                                Canvas.Top="{TemplateBinding ArrowTop}"
                                Width="12"
                                Height="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="2"
                                Visibility="Collapsed">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="18"
                                        Opacity="0.12"
                                        ShadowDepth="4"
                                        Color="#1F2937" />
                                </Border.Effect>
                                <Border.RenderTransform>
                                    <RotateTransform Angle="45" />
                                </Border.RenderTransform>
                            </Border>
                        </Canvas>

                        <Border
                            Margin="{TemplateBinding MenuContentMargin}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="24"
                                    Opacity="0.14"
                                    ShadowDepth="6"
                                    Color="#1F2937" />
                            </Border.Effect>
                            <ScrollViewer
                                MaxHeight="{TemplateBinding MaxHeight}"
                                Padding="0,4"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto">
                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle" />
                            </ScrollViewer>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowArrowVisual" Value="True">
                            <Setter TargetName="Arrow" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style BasedOn="{StaticResource NDropdownMenuBaseStyle}" TargetType="{x:Type controls:NDropdownMenu}"/>

    <Style x:Key="NDropdownItemBaseStyle" TargetType="{x:Type controls:NDropdownItem}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Secondary.Brush}" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NDropdownItem}">
                    <Grid SnapsToDevicePixels="True">
                        <Border
                            x:Name="RenderHost"
                            Margin="4,2"
                            Padding="12,8"
                            Background="Transparent"
                            CornerRadius="6"
                            Visibility="Collapsed">
                            <ContentPresenter Content="{TemplateBinding RenderContent}" />
                        </Border>

                        <Grid x:Name="OptionHost" Height="{TemplateBinding OptionHeight}">
                            <Border
                                x:Name="OptionBackground"
                                Margin="4,0"
                                Background="Transparent"
                                CornerRadius="6" />

                            <DockPanel
                                Height="{TemplateBinding OptionHeight}"
                                LastChildFill="True"
                                TextElement.FontSize="{TemplateBinding OptionFontSize}"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                                <ContentPresenter
                                    Width="{TemplateBinding PrefixWidth}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding Icon}"
                                    DockPanel.Dock="Left"
                                    RecognizesAccessKey="False" />

                                <Grid Width="{TemplateBinding SuffixWidth}" DockPanel.Dock="Right">
                                    <StackPanel
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Right"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                        <ContentPresenter
                                            x:Name="SuffixPresenter"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Content="{TemplateBinding SuffixContent}"
                                            Visibility="Collapsed" />

                                        <Path
                                            x:Name="SubmenuChevron"
                                            Width="14"
                                            Height="14"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Data="{StaticResource Dropdown.SubmenuChevron}"
                                            Fill="{TemplateBinding Foreground}"
                                            Stretch="Uniform"
                                            Visibility="Collapsed" />
                                    </StackPanel>
                                </Grid>

                                <ContentPresenter
                                    VerticalAlignment="Center"
                                    ContentSource="Header"
                                    RecognizesAccessKey="True" />
                            </DockPanel>
                        </Grid>

                        <Popup
                            x:Name="PART_Popup"
                            AllowsTransparency="True"
                            Focusable="False"
                            HorizontalOffset="-4"
                            IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                            Placement="Right"
                            PlacementTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                            PopupAnimation="None"
                            VerticalOffset="-8">
                            <Border
                                Background="{DynamicResource Theme.Surface.0.Brush}"
                                BorderBrush="{DynamicResource Theme.Border.Brush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="24"
                                        Opacity="0.14"
                                        ShadowDepth="6"
                                        Color="#1F2937" />
                                </Border.Effect>
                                <ScrollViewer
                                    MaxHeight="{TemplateBinding MenuMaxHeight}"
                                    Padding="0,4"
                                    HorizontalScrollBarVisibility="Disabled"
                                    VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Cycle" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="EntryKind" Value="{x:Static controls:NDropdownEntryKind.Render}">
                            <Setter TargetName="RenderHost" Property="Visibility" Value="Visible" />
                            <Setter TargetName="OptionHost" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <Trigger Property="HasSuffix" Value="True">
                            <Setter TargetName="SuffixPresenter" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <Trigger Property="HasItems" Value="True">
                            <Setter TargetName="SubmenuChevron" Property="Visibility" Value="Visible" />
                            <Setter TargetName="SuffixPresenter" Property="Margin" Value="0,0,6,0" />
                        </Trigger>

                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="OptionBackground" Property="Background" Value="{DynamicResource Theme.Fill.Hover.Brush}" />
                        </Trigger>

                        <Trigger Property="IsCurrentSelection" Value="True">
                            <Setter TargetName="OptionBackground" Property="Background" Value="{DynamicResource Primary.Third.Brush}" />
                            <Setter Property="Foreground" Value="{DynamicResource Primary.First.Brush}" />
                        </Trigger>

                        <Trigger Property="IsSelectionPath" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Primary.First.Brush}" />
                        </Trigger>

                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Primary.First.Brush}" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="OptionHost" Property="Opacity" Value="0.5" />
                        </Trigger>

                        <Trigger Property="EntryKind" Value="{x:Static controls:NDropdownEntryKind.GroupHeader}">
                            <Setter TargetName="OptionBackground" Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Tertiary.Brush}" />
                            <Setter TargetName="SubmenuChevron" Property="Visibility" Value="Collapsed" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style BasedOn="{StaticResource NDropdownItemBaseStyle}" TargetType="{x:Type controls:NDropdownItem}"/>
</ResourceDictionary>

<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:NaiveUI.NControls.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/NaiveUI.NControls;component/Themes/ThemeTokens.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style TargetType="{x:Type controls:NDropdown}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NDropdown}">
                    <Grid SnapsToDevicePixels="True">
                        <ContentPresenter ContentSource="Content" />
                        <Popup
                            x:Name="PART_Popup"
                            AllowsTransparency="True"
                            Focusable="False"
                            Placement="Custom"
                            StaysOpen="True">
                            <Grid x:Name="PART_PopupRoot" Background="Transparent">
                                <Canvas x:Name="PART_ArrowLayer" IsHitTestVisible="False">
                                    <Border
                                        x:Name="PART_Arrow"
                                        Width="12"
                                        Height="12"
                                        Background="{DynamicResource Theme.Surface.0.Brush}"
                                        BorderBrush="{DynamicResource Theme.Border.Brush}"
                                        BorderThickness="1"
                                        CornerRadius="2"
                                        Visibility="Collapsed">
                                        <Border.Effect>
                                            <DropShadowEffect
                                                BlurRadius="18"
                                                Opacity="0.12"
                                                ShadowDepth="4"
                                                Color="#1F2937" />
                                        </Border.Effect>
                                        <Border.RenderTransform>
                                            <RotateTransform Angle="45" />
                                        </Border.RenderTransform>
                                    </Border>
                                </Canvas>
                                <controls:NDropdownMenu
                                    x:Name="PART_Menu"
                                    MaxHeight="{TemplateBinding MaxMenuHeight}"
                                    Panel.ZIndex="1" />
                            </Grid>
                        </Popup>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NDropdownMenu}">
        <Setter Property="Background" Value="{DynamicResource Theme.Surface.0.Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border.Brush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="MinWidth" Value="144" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NDropdownMenu}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8"
                        SnapsToDevicePixels="True">
                        <Border.Effect>
                            <DropShadowEffect
                                BlurRadius="24"
                                Opacity="0.14"
                                ShadowDepth="6"
                                Color="#1F2937" />
                        </Border.Effect>
                        <ScrollViewer
                            HorizontalScrollBarVisibility="Disabled"
                            MaxHeight="{TemplateBinding MaxHeight}"
                            Padding="0,4"
                            VerticalScrollBarVisibility="Auto">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NDropdownItem}">
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Secondary.Brush}" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NDropdownItem}">
                    <Grid SnapsToDevicePixels="True">
                        <Border
                            x:Name="DividerHost"
                            Height="1"
                            Margin="8,4"
                            Background="{DynamicResource Theme.Border.Brush}"
                            Visibility="Collapsed" />

                        <Border
                            x:Name="RenderHost"
                            Margin="4,2"
                            Padding="12,8"
                            Background="Transparent"
                            CornerRadius="6"
                            Visibility="Collapsed">
                            <ContentPresenter Content="{TemplateBinding RenderContent}" />
                        </Border>

                        <Grid
                            x:Name="OptionHost"
                            Height="{TemplateBinding OptionHeight}">
                            <Border
                                x:Name="OptionBackground"
                                Margin="4,0"
                                Background="Transparent"
                                CornerRadius="6" />

                            <DockPanel
                                x:Name="OptionContent"
                                Height="{TemplateBinding OptionHeight}"
                                LastChildFill="True"
                                TextElement.FontSize="{TemplateBinding OptionFontSize}"
                                TextElement.Foreground="{TemplateBinding Foreground}">
                                <ContentPresenter
                                    x:Name="PrefixPresenter"
                                    Width="{Binding PrefixWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    DockPanel.Dock="Left"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding IconContent}"
                                    RecognizesAccessKey="False" />

                                <Grid
                                    Width="{Binding SuffixWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    DockPanel.Dock="Right">
                                    <ContentPresenter
                                        x:Name="SuffixPresenter"
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Center"
                                        Content="{TemplateBinding SuffixContent}"
                                        Visibility="Collapsed" />
                                </Grid>

                                <ContentPresenter
                                    x:Name="LabelPresenter"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding LabelContent}" />
                            </DockPanel>
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="EntryKind" Value="{x:Static controls:NDropdownEntryKind.Divider}">
                            <Setter TargetName="DividerHost" Property="Visibility" Value="Visible" />
                            <Setter TargetName="OptionHost" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <Trigger Property="EntryKind" Value="{x:Static controls:NDropdownEntryKind.Render}">
                            <Setter TargetName="RenderHost" Property="Visibility" Value="Visible" />
                            <Setter TargetName="OptionHost" Property="Visibility" Value="Collapsed" />
                        </Trigger>

                        <Trigger Property="HasSuffix" Value="True">
                            <Setter TargetName="SuffixPresenter" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="OptionBackground" Property="Background" Value="{DynamicResource Theme.Fill.Hover.Brush}" />
                        </Trigger>

                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="OptionBackground" Property="Background" Value="{DynamicResource Primary.Third.Brush}" />
                            <Setter Property="Foreground" Value="{DynamicResource Primary.First.Brush}" />
                        </Trigger>

                        <Trigger Property="IsDisabled" Value="True">
                            <Setter TargetName="OptionHost" Property="Opacity" Value="0.5" />
                        </Trigger>

                        <Trigger Property="EntryKind" Value="{x:Static controls:NDropdownEntryKind.GroupHeader}">
                            <Setter TargetName="OptionBackground" Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Tertiary.Brush}" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

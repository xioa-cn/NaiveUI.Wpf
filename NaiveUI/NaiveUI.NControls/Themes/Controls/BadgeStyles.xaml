<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:NaiveUI.NControls.Controls">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/NaiveUI.NControls;component/Themes/ThemeTokens.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="NBadgeBaseStyle" TargetType="{x:Type controls:NBadge}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Inverse.Brush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="6,0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NBadge}">
                    <Grid ClipToBounds="False">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding Content}"
                            ContentStringFormat="{TemplateBinding ContentStringFormat}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                            RecognizesAccessKey="True" />

                        <Grid
                            x:Name="BadgeOverlay"
                            Margin="{TemplateBinding ResolvedBadgeMargin}"
                            Panel.ZIndex="1"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            IsHitTestVisible="False"
                            Visibility="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ShowBadge, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid>
                                <Border
                                    x:Name="ProcessingWave"
                                    Background="{TemplateBinding ResolvedBackground}"
                                    CornerRadius="{TemplateBinding ResolvedCornerRadius}"
                                    Opacity="0"
                                    RenderTransformOrigin="0.5,0.5"
                                    Visibility="Collapsed">
                                    <Border.RenderTransform>
                                        <ScaleTransform x:Name="ProcessingWaveScale" ScaleX="0.8" ScaleY="0.8" />
                                    </Border.RenderTransform>
                                </Border>

                                <Border
                                    x:Name="PART_BadgeSurface"
                                    MinWidth="{TemplateBinding ResolvedMinWidth}"
                                    Height="{TemplateBinding ResolvedHeight}"
                                    MinHeight="{TemplateBinding ResolvedHeight}"
                                    Padding="{TemplateBinding Padding}"
                                    Background="{TemplateBinding ResolvedBackground}"
                                    CornerRadius="{TemplateBinding ResolvedCornerRadius}">
                                    <Grid>
                                        <TextBlock
                                            x:Name="BadgeText"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            FontSize="{TemplateBinding FontSize}"
                                            FontWeight="{TemplateBinding FontWeight}"
                                            Foreground="{TemplateBinding Foreground}"
                                            Text="{TemplateBinding DisplayText}" />

                                        <ContentPresenter
                                            x:Name="BadgeContentPresenter"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Content="{TemplateBinding DisplayValueContent}"
                                            RecognizesAccessKey="True"
                                            TextElement.FontSize="{TemplateBinding FontSize}"
                                            TextElement.FontWeight="{TemplateBinding FontWeight}"
                                            TextElement.Foreground="{TemplateBinding Foreground}"
                                            Visibility="Collapsed" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="UseTextDisplay" Value="False">
                            <Setter TargetName="BadgeText" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="BadgeContentPresenter" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <Trigger Property="HasHostContent" Value="False">
                            <Setter TargetName="BadgeOverlay" Property="HorizontalAlignment" Value="Left" />
                            <Setter TargetName="BadgeOverlay" Property="VerticalAlignment" Value="Top" />
                        </Trigger>

                        <Trigger Property="Dot" Value="True">
                            <Setter TargetName="PART_BadgeSurface" Property="Width" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ResolvedDotSize}" />
                            <Setter TargetName="PART_BadgeSurface" Property="Height" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ResolvedDotSize}" />
                            <Setter TargetName="PART_BadgeSurface" Property="MinWidth" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ResolvedDotSize}" />
                            <Setter TargetName="PART_BadgeSurface" Property="MinHeight" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ResolvedDotSize}" />
                            <Setter TargetName="PART_BadgeSurface" Property="Padding" Value="0" />
                            <Setter TargetName="PART_BadgeSurface" Property="CornerRadius" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ResolvedDotCornerRadius}" />
                            <Setter TargetName="BadgeText" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="BadgeContentPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="ProcessingWave" Property="CornerRadius" Value="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=ResolvedDotCornerRadius}" />
                        </Trigger>

                        <Trigger Property="Processing" Value="True">
                            <Setter TargetName="ProcessingWave" Property="Visibility" Value="Visible" />
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="BadgeProcessingStoryboard">
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetName="ProcessingWaveScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            Duration="0:0:1.4"
                                            From="0.8"
                                            To="2.4" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="ProcessingWaveScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            Duration="0:0:1.4"
                                            From="0.8"
                                            To="2.4" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="ProcessingWave"
                                            Storyboard.TargetProperty="Opacity"
                                            Duration="0:0:1.4"
                                            From="0.6"
                                            To="0" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="BadgeProcessingStoryboard" />
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style BasedOn="{StaticResource NBadgeBaseStyle}" TargetType="{x:Type controls:NBadge}"/>
</ResourceDictionary>

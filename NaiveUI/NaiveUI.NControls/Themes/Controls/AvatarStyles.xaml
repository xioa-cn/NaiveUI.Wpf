<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:NaiveUI.NControls.Controls"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/NaiveUI.NControls;component/Themes/Controls/PathResources.xaml" />
        <ResourceDictionary Source="/NaiveUI.NControls;component/Themes/ThemeTokens.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <sys:Double x:Key="Avatar.Badge.MinSize">18</sys:Double>
    <sys:Double x:Key="Avatar.Content.MinFontSize">12</sys:Double>

    <Style TargetType="{x:Type controls:NAvatar}">
        <Setter Property="Width" Value="{Binding Size, RelativeSource={RelativeSource Self}}" />
        <Setter Property="Height" Value="{Binding Size, RelativeSource={RelativeSource Self}}" />
        <Setter Property="Background" Value="{DynamicResource Theme.Fill.2.Brush}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary.Brush}" />
        <Setter Property="PlaceholderForeground" Value="{DynamicResource Theme.Text.Tertiary.Brush}" />
        <Setter Property="BadgeBackground" Value="{DynamicResource Error.First.Brush}" />
        <Setter Property="BadgeForeground" Value="{DynamicResource Theme.Text.Inverse.Brush}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="{StaticResource Avatar.Content.MinFontSize}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NAvatar}">
                    <Grid Width="{TemplateBinding Size}" Height="{TemplateBinding Size}">
                        <Border
                            x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding ResolvedCornerRadius}">
                            <Grid ClipToBounds="True">
                                <Image
                                    x:Name="PART_Image"
                                    Source="{TemplateBinding ResolvedImageSource}"
                                    Stretch="{TemplateBinding ImageStretch}"
                                    Visibility="Collapsed" />

                                <Grid>
                                    <ContentPresenter
                                        x:Name="AvatarVisualContentPresenter"
                                        Margin="{TemplateBinding ResolvedContentMargin}"
                                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                        Content="{TemplateBinding DisplayVisualContent}"
                                        RecognizesAccessKey="True"
                                        Visibility="Collapsed" />

                                    <Viewbox
                                        x:Name="AvatarTextPresenter"
                                        Margin="{TemplateBinding ResolvedContentMargin}"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Stretch"
                                        Stretch="Uniform"
                                        StretchDirection="DownOnly"
                                        Visibility="Collapsed">
                                        <TextBlock
                                            FontSize="{TemplateBinding ResolvedFontSize}"
                                            FontWeight="{TemplateBinding FontWeight}"
                                            Foreground="{TemplateBinding Foreground}"
                                            Text="{TemplateBinding DisplayTextContent}"
                                            TextAlignment="Center" />
                                    </Viewbox>

                                    <Viewbox
                                        x:Name="PlaceholderViewbox"
                                        Margin="{TemplateBinding ResolvedPlaceholderMargin}"
                                        Stretch="Uniform"
                                        Visibility="Collapsed">
                                        <Path
                                            Data="{StaticResource Avatar_Normal}"
                                            Fill="{TemplateBinding PlaceholderForeground}"
                                            Stretch="Uniform" />
                                    </Viewbox>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border
                            x:Name="AvatarBadge"
                            MinWidth="{TemplateBinding ResolvedBadgeMinSize}"
                            MinHeight="{TemplateBinding ResolvedBadgeMinSize}"
                            Margin="{TemplateBinding ResolvedBadgeMargin}"
                            Padding="{TemplateBinding ResolvedBadgePadding}"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Background="{TemplateBinding BadgeBackground}"
                            BorderBrush="{DynamicResource Theme.Surface.0.Brush}"
                            BorderThickness="2"
                            CornerRadius="{TemplateBinding BadgeCornerRadius}"
                            Visibility="{Binding Badge, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource AvatarBadgeToVisibilityConverter}}">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="{TemplateBinding ResolvedBadgeFontSize}"
                                FontWeight="SemiBold"
                                Foreground="{TemplateBinding BadgeForeground}"
                                Text="{TemplateBinding Badge}" />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsImageVisible" Value="True">
                            <Setter TargetName="PART_Image" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasCustomContent" Value="True">
                            <Setter TargetName="AvatarVisualContentPresenter" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasTextContent" Value="True">
                            <Setter TargetName="AvatarTextPresenter" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="ShowPlaceholder" Value="True">
                            <Setter TargetName="PlaceholderViewbox" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsCompactBadge" Value="True">
                            <Setter TargetName="AvatarBadge" Property="Width" Value="{Binding ResolvedBadgeMinSize, RelativeSource={RelativeSource TemplatedParent}}" />
                            <Setter TargetName="AvatarBadge" Property="Padding" Value="0" />
                        </Trigger>
                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

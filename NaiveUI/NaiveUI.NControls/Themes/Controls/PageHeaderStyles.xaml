<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:NaiveUI.NControls.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/NaiveUI.NControls;component/Themes/ThemeTokens.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="NPageHeaderBackButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Secondary.Brush}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <ContentPresenter
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        RecognizesAccessKey="True"
                        TextElement.Foreground="{TemplateBinding Foreground}" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Primary.Hover.Brush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Foreground" Value="{DynamicResource Primary.Pressed.Brush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NPageHeader}">
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary.Brush}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NPageHeader}">
                    <StackPanel>
                        <ContentPresenter
                            x:Name="HeaderPresenter"
                            Margin="0,0,0,20"
                            Content="{TemplateBinding HeaderContent}"
                            Visibility="Collapsed" />

                        <Grid x:Name="MainGrid" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal">
                                <Button
                                    x:Name="PART_BackButton"
                                    Margin="0,0,16,0"
                                    Command="{TemplateBinding OnBack}"
                                    CommandParameter="{TemplateBinding BackCommandParameter}"
                                    Style="{StaticResource NPageHeaderBackButtonStyle}"
                                    Visibility="Collapsed">
                                    <ContentPresenter Content="{TemplateBinding ResolvedBackContent}" />
                                </Button>

                                <ContentPresenter
                                    x:Name="AvatarPresenter"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding AvatarContent}"
                                    Visibility="Collapsed" />

                                <ContentPresenter
                                    x:Name="TitlePresenter"
                                    Margin="0,0,16,0"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding ResolvedTitleContent}"
                                    TextElement.FontSize="18"
                                    TextElement.FontWeight="SemiBold"
                                    TextElement.Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                                    Visibility="Collapsed" />

                                <ContentPresenter
                                    x:Name="SubtitlePresenter"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding ResolvedSubtitleContent}"
                                    TextElement.FontSize="14"
                                    TextElement.Foreground="{DynamicResource Theme.Text.Tertiary.Brush}"
                                    Visibility="Collapsed" />
                            </StackPanel>

                            <ContentPresenter
                                x:Name="ExtraPresenter"
                                Grid.Column="1"
                                Margin="20,0,0,0"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding ResolvedExtraContent}"
                                Visibility="Collapsed" />
                        </Grid>

                        <ContentPresenter
                            x:Name="DefaultPresenter"
                            Margin="0,20,0,0"
                            Content="{TemplateBinding Content}"
                            TextElement.FontSize="14"
                            TextElement.Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                            Visibility="Collapsed" />

                        <ContentPresenter
                            x:Name="FooterPresenter"
                            Margin="0,20,0,0"
                            Content="{TemplateBinding FooterContent}"
                            TextElement.FontSize="14"
                            TextElement.Foreground="{DynamicResource Theme.Text.Primary.Brush}"
                            Visibility="Collapsed" />
                    </StackPanel>

                    <ControlTemplate.Triggers>
                        <Trigger Property="HasHeaderSection" Value="True">
                            <Setter TargetName="HeaderPresenter" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasMainSection" Value="True">
                            <Setter TargetName="MainGrid" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="ShowBack" Value="True">
                            <Setter TargetName="PART_BackButton" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasAvatarSection" Value="True">
                            <Setter TargetName="AvatarPresenter" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasTitleSection" Value="True">
                            <Setter TargetName="TitlePresenter" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasSubtitleSection" Value="True">
                            <Setter TargetName="SubtitlePresenter" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasExtraSection" Value="True">
                            <Setter TargetName="ExtraPresenter" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasDefaultSection" Value="True">
                            <Setter TargetName="DefaultPresenter" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="HasFooterSection" Value="True">
                            <Setter TargetName="FooterPresenter" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:NaiveUI.NControls.Controls">

    <Style TargetType="{x:Type controls:NBreadcrumb}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NBreadcrumb}">
                    <Border Background="Transparent">
                        <ItemsPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Setter Property="ItemsPanel">
            <Setter.Value>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:NBreadcrumbItem}">
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Tertiary.Brush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NBreadcrumbItem}">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <Border
                            x:Name="LinkBorder"
                            Padding="4"
                            Background="Transparent"
                            CornerRadius="3">
                            <ContentPresenter
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True"
                                TextElement.FontSize="14"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>

                        <ContentPresenter
                            x:Name="SeparatorPresenter"
                            Margin="8,0"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding ResolvedSeparatorContent}"
                            TextElement.FontSize="14"
                            TextElement.Foreground="{DynamicResource Theme.Text.Tertiary.Brush}" />
                    </StackPanel>

                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowResolvedSeparator" Value="False">
                            <Setter TargetName="SeparatorPresenter" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="CanInvoke" Value="True">
                            <Setter Property="Cursor" Value="Hand" />
                        </Trigger>
                        <Trigger Property="CanInvoke" Value="False">
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                        <Trigger Property="IsLast" Value="True">
                            <Setter Property="Cursor" Value="Arrow" />
                            <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Secondary.Brush}" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="CanInvoke" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="LinkBorder" Property="Background" Value="{DynamicResource Theme.Fill.Hover.Brush}" />
                            <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Secondary.Brush}" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="CanInvoke" Value="True" />
                                <Condition Property="IsPointerPressed" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="LinkBorder" Property="Background" Value="{DynamicResource Theme.Fill.2Pressed.Brush}" />
                            <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Secondary.Brush}" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:NaiveUI.NControls.Controls">
    <Style TargetType="{x:Type controls:NSwitch}">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary.Brush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NSwitch}">
                    <Grid ClipToBounds="False">
                        <Border
                            x:Name="FocusRing"
                            Margin="-2"
                            Background="Transparent"
                            BorderBrush="{TemplateBinding ResolvedFocusRingBrush}"
                            BorderThickness="0"
                            CornerRadius="{TemplateBinding ResolvedRailCornerRadius}"
                            Opacity="1" />

                        <Border
                            x:Name="PART_Rail"
                            Width="{TemplateBinding ResolvedTrackWidth}"
                            MinWidth="{TemplateBinding ResolvedTrackMinWidth}"
                            Height="{TemplateBinding ResolvedTrackHeight}"
                            Background="{TemplateBinding ResolvedRailBrush}"
                            CornerRadius="{TemplateBinding ResolvedRailCornerRadius}">
                            <Grid ClipToBounds="False">
                                <ContentPresenter
                                    x:Name="CheckedContentPresenter"
                                    Margin="{TemplateBinding ResolvedCheckedContentMargin}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding CheckedContent}"
                                    RecognizesAccessKey="True"
                                    TextElement.FontFamily="{TemplateBinding ResolvedContentFontFamily}"
                                    TextElement.FontSize="{TemplateBinding ResolvedContentFontSize}"
                                    TextElement.FontWeight="{TemplateBinding ResolvedContentFontWeight}"
                                    TextElement.Foreground="{TemplateBinding ResolvedContentBrush}"
                                    Visibility="Collapsed">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="{x:Type controls:NIcon}">
                                            <Setter Property="IconBrush" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type controls:NSwitch}}, Path=ResolvedContentBrush}" />
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>

                                <ContentPresenter
                                    x:Name="UncheckedContentPresenter"
                                    Margin="{TemplateBinding ResolvedUncheckedContentMargin}"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Content="{TemplateBinding UncheckedContent}"
                                    RecognizesAccessKey="True"
                                    TextElement.FontFamily="{TemplateBinding ResolvedContentFontFamily}"
                                    TextElement.FontSize="{TemplateBinding ResolvedContentFontSize}"
                                    TextElement.FontWeight="{TemplateBinding ResolvedContentFontWeight}"
                                    TextElement.Foreground="{TemplateBinding ResolvedContentBrush}"
                                    Visibility="Collapsed">
                                    <ContentPresenter.Resources>
                                        <Style TargetType="{x:Type controls:NIcon}">
                                            <Setter Property="IconBrush" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type controls:NSwitch}}, Path=ResolvedContentBrush}" />
                                        </Style>
                                    </ContentPresenter.Resources>
                                </ContentPresenter>

                                <Border
                                    x:Name="Thumb"
                                    Width="{TemplateBinding ResolvedThumbSize}"
                                    Height="{TemplateBinding ResolvedThumbSize}"
                                    Margin="{TemplateBinding ResolvedThumbMargin}"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Background="{TemplateBinding ResolvedButtonBrush}"
                                    CornerRadius="{TemplateBinding ResolvedThumbCornerRadius}">
                                    <Border.Effect>
                                        <DropShadowEffect
                                            BlurRadius="6"
                                            Direction="270"
                                            Opacity="0.2"
                                            ShadowDepth="1" />
                                    </Border.Effect>
                                    <Border.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform x:Name="ThumbScaleTransform" ScaleX="1" ScaleY="1" />
                                            <TranslateTransform x:Name="PART_ThumbTransform" X="0" />
                                        </TransformGroup>
                                    </Border.RenderTransform>

                                    <Grid>
                                        <Viewbox
                                            x:Name="LoadingIndicator"
                                            Width="{TemplateBinding ResolvedLoadingIndicatorSize}"
                                            Height="{TemplateBinding ResolvedLoadingIndicatorSize}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Visibility="Collapsed">
                                            <Path
                                                Data="M 7,1 A 6,6 0 1 1 1,7"
                                                Stroke="{TemplateBinding ResolvedLoadingBrush}"
                                                StrokeEndLineCap="Round"
                                                StrokeStartLineCap="Round"
                                                StrokeThickness="{TemplateBinding LoadingStrokeThickness}">
                                                <Path.RenderTransform>
                                                    <RotateTransform x:Name="LoadingRotateTransform" CenterX="7" CenterY="7" />
                                                </Path.RenderTransform>
                                            </Path>
                                        </Viewbox>

                                        <ContentPresenter
                                            x:Name="ThumbContentPresenter"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Content="{TemplateBinding DisplayThumbContent}"
                                            RecognizesAccessKey="True"
                                            TextElement.FontFamily="{TemplateBinding ResolvedContentFontFamily}"
                                            TextElement.FontSize="{TemplateBinding ResolvedContentFontSize}"
                                            TextElement.FontWeight="{TemplateBinding ResolvedContentFontWeight}"
                                            TextElement.Foreground="{TemplateBinding ResolvedThumbContentBrush}"
                                            Visibility="Collapsed">
                                            <ContentPresenter.Resources>
                                                <Style TargetType="{x:Type controls:NIcon}">
                                                    <Setter Property="IconBrush" Value="{Binding RelativeSource={RelativeSource AncestorType={x:Type controls:NSwitch}}, Path=ResolvedThumbContentBrush}" />
                                                </Style>
                                            </ContentPresenter.Resources>
                                        </ContentPresenter>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="Size" Value="Tiny">
                            <Setter Property="FontSize" Value="10" />
                        </Trigger>
                        <Trigger Property="Size" Value="Small">
                            <Setter Property="FontSize" Value="12" />
                        </Trigger>
                        <Trigger Property="Size" Value="Medium">
                            <Setter Property="FontSize" Value="12" />
                        </Trigger>
                        <Trigger Property="Size" Value="Large">
                            <Setter Property="FontSize" Value="14" />
                        </Trigger>

                        <Trigger Property="HasThumbContent" Value="True">
                            <Setter TargetName="ThumbContentPresenter" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="HasCheckedContent" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="CheckedContentPresenter" Property="Visibility" Value="Visible" />
                        </MultiTrigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="False" />
                                <Condition Property="HasUncheckedContent" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="UncheckedContentPresenter" Property="Visibility" Value="Visible" />
                        </MultiTrigger>

                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsPressed" Value="True" />
                                <Condition Property="RubberBand" Value="True" />
                                <Condition Property="Loading" Value="False" />
                            </MultiTrigger.Conditions>
                            <MultiTrigger.EnterActions>
                                <BeginStoryboard x:Name="SwitchRubberBandBeginStoryboard">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="ThumbScaleTransform"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1.12"
                                            Duration="0:0:0.12" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="ThumbScaleTransform"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1.12"
                                            Duration="0:0:0.12" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.EnterActions>
                            <MultiTrigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="ThumbScaleTransform"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1"
                                            Duration="0:0:0.12" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="ThumbScaleTransform"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1"
                                            Duration="0:0:0.12" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiTrigger.ExitActions>
                        </MultiTrigger>

                        <Trigger Property="Loading" Value="True">
                            <Setter TargetName="LoadingIndicator" Property="Visibility" Value="Visible" />
                            <Setter TargetName="ThumbContentPresenter" Property="Visibility" Value="Collapsed" />
                            <Setter Property="Cursor" Value="Arrow" />
                            <Trigger.EnterActions>
                                <BeginStoryboard x:Name="SwitchLoadingSpinBeginStoryboard">
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            By="360"
                                            Storyboard.TargetName="LoadingRotateTransform"
                                            Storyboard.TargetProperty="Angle"
                                            Duration="0:0:0.8" />
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="SwitchLoadingSpinBeginStoryboard" />
                            </Trigger.ExitActions>
                        </Trigger>

                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="FocusRing" Property="BorderThickness" Value="2" />
                        </Trigger>

                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="FocusRing" Property="BorderThickness" Value="2" />
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

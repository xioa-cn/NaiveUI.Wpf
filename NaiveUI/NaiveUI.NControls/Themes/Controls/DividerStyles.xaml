<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:NaiveUI.NControls.Controls">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/NaiveUI.NControls;component/Themes/ThemeTokens.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="NDividerBaseStyle" TargetType="{x:Type controls:NDivider}">
        <Setter Property="Foreground" Value="{DynamicResource Theme.Text.Primary.Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource Theme.Border.Brush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,24,0,24" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NDivider}">
                    <Grid Background="{TemplateBinding Background}">
                        <Path
                            x:Name="VerticalLine"
                            Width="{TemplateBinding ResolvedLineThickness}"
                            Height="{TemplateBinding ResolvedVerticalHeight}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Data="M0.5,0 L0.5,1"
                            Stretch="Fill"
                            Stroke="{TemplateBinding BorderBrush}"
                            StrokeThickness="{TemplateBinding ResolvedLineThickness}"
                            Visibility="Collapsed" />

                        <Grid x:Name="HorizontalRoot">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition x:Name="LeftLineColumn" Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition x:Name="RightLineColumn" Width="*" />
                            </Grid.ColumnDefinitions>

                            <Path
                                x:Name="LeftLine"
                                Grid.Column="0"
                                Grid.ColumnSpan="3"
                                Height="{TemplateBinding ResolvedLineThickness}"
                                VerticalAlignment="Center"
                                Data="M0,0.5 L1,0.5"
                                Stretch="Fill"
                                Stroke="{TemplateBinding BorderBrush}"
                                StrokeThickness="{TemplateBinding ResolvedLineThickness}" />

                            <ContentPresenter
                                x:Name="TitlePresenter"
                                Grid.Column="1"
                                Margin="12,0"
                                VerticalAlignment="Center"
                                Content="{TemplateBinding ResolvedTitleContent}"
                                ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                TextElement.FontWeight="{TemplateBinding FontWeight}"
                                TextElement.Foreground="{TemplateBinding Foreground}"
                                Visibility="Collapsed" />

                            <Path
                                x:Name="RightLine"
                                Grid.Column="2"
                                Height="{TemplateBinding ResolvedLineThickness}"
                                VerticalAlignment="Center"
                                Data="M0,0.5 L1,0.5"
                                Stretch="Fill"
                                Stroke="{TemplateBinding BorderBrush}"
                                StrokeThickness="{TemplateBinding ResolvedLineThickness}"
                                Visibility="Collapsed" />
                        </Grid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="HasTitle" Value="True">
                            <Setter TargetName="LeftLine" Property="Grid.ColumnSpan" Value="1" />
                            <Setter TargetName="TitlePresenter" Property="Visibility" Value="Visible" />
                            <Setter TargetName="RightLine" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="TitlePlacement" Value="Left">
                            <Setter TargetName="LeftLineColumn" Property="Width" Value="28" />
                            <Setter TargetName="RightLineColumn" Property="Width" Value="*" />
                        </Trigger>
                        <Trigger Property="TitlePlacement" Value="Right">
                            <Setter TargetName="LeftLineColumn" Property="Width" Value="*" />
                            <Setter TargetName="RightLineColumn" Property="Width" Value="28" />
                        </Trigger>
                        <Trigger Property="Dashed" Value="True">
                            <Setter TargetName="LeftLine" Property="StrokeDashArray" Value="3,2" />
                            <Setter TargetName="RightLine" Property="StrokeDashArray" Value="3,2" />
                        </Trigger>
                        <Trigger Property="Vertical" Value="True">
                            <Setter TargetName="HorizontalRoot" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="VerticalLine" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Vertical" Value="True">
                <Setter Property="Margin" Value="8,0" />
            </Trigger>
        </Style.Triggers>
    </Style>
    <Style BasedOn="{StaticResource NDividerBaseStyle}" TargetType="{x:Type controls:NDivider}"/>
</ResourceDictionary>

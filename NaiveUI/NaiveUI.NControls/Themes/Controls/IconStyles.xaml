<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:NaiveUI.NControls.Controls">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/NaiveUI.NControls;component/Themes/ThemeTokens.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="NIconBaseStyle" TargetType="{x:Type controls:NIcon}">
        <Setter Property="Size" Value="20" />
        <Setter Property="Width" Value="{Binding ResolvedSize, RelativeSource={RelativeSource Self}}" />
        <Setter Property="Height" Value="{Binding ResolvedSize, RelativeSource={RelativeSource Self}}" />
        <Setter Property="Stretch" Value="Uniform" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NIcon}">
                    <Grid Width="{TemplateBinding Width}" Height="{TemplateBinding Height}">
                        <Viewbox
                            x:Name="ContentHost"
                            Stretch="{TemplateBinding Stretch}"
                            StretchDirection="Both">
                            <ContentPresenter Content="{TemplateBinding ResolvedContent}" Opacity="{TemplateBinding ResolvedOpacity}" />
                        </Viewbox>

                        <Viewbox
                            x:Name="PathHost"
                            Stretch="{TemplateBinding Stretch}"
                            StretchDirection="Both"
                            Visibility="Collapsed">
                            <Grid>
                                <Path
                                    x:Name="FillPathHost"
                                    Data="{TemplateBinding Data}"
                                    Fill="{TemplateBinding ResolvedBrush}"
                                    Opacity="{TemplateBinding ResolvedOpacity}"
                                    Stretch="{TemplateBinding Stretch}" />
                                <Path
                                    x:Name="StrokePathHost"
                                    Data="{TemplateBinding Data}"
                                    Opacity="{TemplateBinding ResolvedOpacity}"
                                    Stretch="{TemplateBinding Stretch}"
                                    Stroke="{TemplateBinding ResolvedBrush}"
                                    StrokeEndLineCap="Round"
                                    StrokeLineJoin="Round"
                                    StrokeStartLineCap="Round"
                                    StrokeThickness="{TemplateBinding ResolvedStrokeThickness}"
                                    Visibility="Collapsed" />
                            </Grid>
                        </Viewbox>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="ResolvedContent" Value="{x:Null}">
                            <Setter TargetName="ContentHost" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PathHost" Property="Visibility" Value="Visible" />
                        </Trigger>

                        <Trigger Property="UseStroke" Value="True">
                            <Setter TargetName="FillPathHost" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="StrokePathHost" Property="Visibility" Value="Visible" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style BasedOn="{StaticResource NIconBaseStyle}" TargetType="{x:Type controls:NIcon}"/>

    <Style x:Key="NIconWrapperBaseStyle" TargetType="{x:Type controls:NIconWrapper}">
        <Setter Property="Size" Value="24" />
        <Setter Property="Color" Value="{DynamicResource Primary.First.Brush}" />
        <Setter Property="Width" Value="{Binding ResolvedSize, RelativeSource={RelativeSource Self}}" />
        <Setter Property="Height" Value="{Binding ResolvedSize, RelativeSource={RelativeSource Self}}" />
        <Setter Property="Background" Value="{Binding Color, RelativeSource={RelativeSource Self}}" />
        <Setter Property="Foreground" Value="{Binding ResolvedForeground, RelativeSource={RelativeSource Self}}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="UseLayoutRounding" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NIconWrapper}">
                    <Border
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding ResolvedCornerRadius}">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding Content}"
                            RecognizesAccessKey="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style BasedOn="{StaticResource NIconWrapperBaseStyle}" TargetType="{x:Type controls:NIconWrapper}"/>
</ResourceDictionary>

<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <sys:String x:Key="NaiveUI.Theme.Name">Dark</sys:String>

    <Color x:Key="Theme.Window.Background.Color">#0F172A</Color>
    <Color x:Key="Theme.Surface.0.Color">#111827</Color>
    <Color x:Key="Theme.Surface.1.Color">#172033</Color>
    <Color x:Key="Theme.Fill.2.Color">#1B2435</Color>
    <Color x:Key="Theme.Fill.2Hover.Color">#243041</Color>
    <Color x:Key="Theme.Fill.2Pressed.Color">#2C3A4F</Color>
    <Color x:Key="Theme.Fill.Hover.Color">#1E293B</Color>
    <Color x:Key="Theme.Border.Color">#344054</Color>
    <Color x:Key="Theme.Border.Strong.Color">#475467</Color>
    <Color x:Key="Theme.Text.Primary.Color">#F8FAFC</Color>
    <Color x:Key="Theme.Text.Secondary.Color">#CBD5E1</Color>
    <Color x:Key="Theme.Text.Tertiary.Color">#94A3B8</Color>
    <Color x:Key="Theme.Text.Inverse.Color">#F8FAFC</Color>
    <Color x:Key="Theme.Tooltip.Background.Color">#334155</Color>
    <Color x:Key="Theme.Tooltip.Border.Color">#475467</Color>
    <Color x:Key="Theme.Tooltip.Foreground.Color">#F8FAFC</Color>
    <Color x:Key="Theme.Hero.Start.Color">#10231A</Color>
    <Color x:Key="Theme.Hero.End.Color">#101D33</Color>
    <Color x:Key="Theme.Hero.Glow.Color">#174A33</Color>

    <Color x:Key="Primary.First.Color">#5FD18D</Color>
    <Color x:Key="Primary.Second.Color">#7BE3A4</Color>
    <Color x:Key="Primary.Hover.Color">#7BE3A4</Color>
    <Color x:Key="Primary.Pressed.Color">#4FB377</Color>
    <Color x:Key="Primary.Third.Color">#143322</Color>
    <Color x:Key="Info.First.Color">#60A5FA</Color>
    <Color x:Key="Info.Second.Color">#93C5FD</Color>
    <Color x:Key="Info.Hover.Color">#93C5FD</Color>
    <Color x:Key="Info.Pressed.Color">#3B82F6</Color>
    <Color x:Key="Info.Third.Color">#12263F</Color>
    <Color x:Key="Success.First.Color">#5FD18D</Color>
    <Color x:Key="Success.Second.Color">#7BE3A4</Color>
    <Color x:Key="Success.Hover.Color">#7BE3A4</Color>
    <Color x:Key="Success.Pressed.Color">#4FB377</Color>
    <Color x:Key="Success.Third.Color">#143322</Color>
    <Color x:Key="Warning.First.Color">#F7B955</Color>
    <Color x:Key="Warning.Second.Color">#F9C97B</Color>
    <Color x:Key="Warning.Hover.Color">#F9C97B</Color>
    <Color x:Key="Warning.Pressed.Color">#D79B3F</Color>
    <Color x:Key="Warning.Third.Color">#3A2A10</Color>
    <Color x:Key="Error.First.Color">#F97066</Color>
    <Color x:Key="Error.Second.Color">#FDA29B</Color>
    <Color x:Key="Error.Hover.Color">#FDA29B</Color>
    <Color x:Key="Error.Pressed.Color">#E35B56</Color>
    <Color x:Key="Error.Third.Color">#3B151A</Color>

    <SolidColorBrush x:Key="Theme.Window.Background.Brush" Color="{StaticResource Theme.Window.Background.Color}" />
    <SolidColorBrush x:Key="Theme.Surface.0.Brush" Color="{StaticResource Theme.Surface.0.Color}" />
    <SolidColorBrush x:Key="Theme.Surface.1.Brush" Color="{StaticResource Theme.Surface.1.Color}" />
    <SolidColorBrush x:Key="Theme.Fill.2.Brush" Color="{StaticResource Theme.Fill.2.Color}" />
    <SolidColorBrush x:Key="Theme.Fill.2Hover.Brush" Color="{StaticResource Theme.Fill.2Hover.Color}" />
    <SolidColorBrush x:Key="Theme.Fill.2Pressed.Brush" Color="{StaticResource Theme.Fill.2Pressed.Color}" />
    <SolidColorBrush x:Key="Theme.Fill.Hover.Brush" Color="{StaticResource Theme.Fill.Hover.Color}" />
    <SolidColorBrush x:Key="Theme.Border.Brush" Color="{StaticResource Theme.Border.Color}" />
    <SolidColorBrush x:Key="Theme.Border.Strong.Brush" Color="{StaticResource Theme.Border.Strong.Color}" />
    <SolidColorBrush x:Key="Theme.Text.Primary.Brush" Color="{StaticResource Theme.Text.Primary.Color}" />
    <SolidColorBrush x:Key="Theme.Text.Secondary.Brush" Color="{StaticResource Theme.Text.Secondary.Color}" />
    <SolidColorBrush x:Key="Theme.Text.Tertiary.Brush" Color="{StaticResource Theme.Text.Tertiary.Color}" />
    <SolidColorBrush x:Key="Theme.Text.Inverse.Brush" Color="{StaticResource Theme.Text.Inverse.Color}" />
    <SolidColorBrush x:Key="Theme.Tooltip.Background.Brush" Color="{StaticResource Theme.Tooltip.Background.Color}" />
    <SolidColorBrush x:Key="Theme.Tooltip.Border.Brush" Color="{StaticResource Theme.Tooltip.Border.Color}" />
    <SolidColorBrush x:Key="Theme.Tooltip.Foreground.Brush" Color="{StaticResource Theme.Tooltip.Foreground.Color}" />

    <SolidColorBrush x:Key="Primary.First.Brush" Color="{StaticResource Primary.First.Color}" />
    <SolidColorBrush x:Key="Primary.Second.Brush" Color="{StaticResource Primary.Second.Color}" />
    <SolidColorBrush x:Key="Primary.Hover.Brush" Color="{StaticResource Primary.Hover.Color}" />
    <SolidColorBrush x:Key="Primary.Pressed.Brush" Color="{StaticResource Primary.Pressed.Color}" />
    <SolidColorBrush x:Key="Primary.Third.Brush" Color="{StaticResource Primary.Third.Color}" />
    <SolidColorBrush x:Key="Info.First.Brush" Color="{StaticResource Info.First.Color}" />
    <SolidColorBrush x:Key="Info.Second.Brush" Color="{StaticResource Info.Second.Color}" />
    <SolidColorBrush x:Key="Info.Hover.Brush" Color="{StaticResource Info.Hover.Color}" />
    <SolidColorBrush x:Key="Info.Pressed.Brush" Color="{StaticResource Info.Pressed.Color}" />
    <SolidColorBrush x:Key="Info.Third.Brush" Color="{StaticResource Info.Third.Color}" />
    <SolidColorBrush x:Key="Success.First.Brush" Color="{StaticResource Success.First.Color}" />
    <SolidColorBrush x:Key="Success.Second.Brush" Color="{StaticResource Success.Second.Color}" />
    <SolidColorBrush x:Key="Success.Hover.Brush" Color="{StaticResource Success.Hover.Color}" />
    <SolidColorBrush x:Key="Success.Pressed.Brush" Color="{StaticResource Success.Pressed.Color}" />
    <SolidColorBrush x:Key="Success.Third.Brush" Color="{StaticResource Success.Third.Color}" />
    <SolidColorBrush x:Key="Warning.First.Brush" Color="{StaticResource Warning.First.Color}" />
    <SolidColorBrush x:Key="Warning.Second.Brush" Color="{StaticResource Warning.Second.Color}" />
    <SolidColorBrush x:Key="Warning.Hover.Brush" Color="{StaticResource Warning.Hover.Color}" />
    <SolidColorBrush x:Key="Warning.Pressed.Brush" Color="{StaticResource Warning.Pressed.Color}" />
    <SolidColorBrush x:Key="Warning.Third.Brush" Color="{StaticResource Warning.Third.Color}" />
    <SolidColorBrush x:Key="Error.First.Brush" Color="{StaticResource Error.First.Color}" />
    <SolidColorBrush x:Key="Error.Second.Brush" Color="{StaticResource Error.Second.Color}" />
    <SolidColorBrush x:Key="Error.Hover.Brush" Color="{StaticResource Error.Hover.Color}" />
    <SolidColorBrush x:Key="Error.Pressed.Brush" Color="{StaticResource Error.Pressed.Color}" />
    <SolidColorBrush x:Key="Error.Third.Brush" Color="{StaticResource Error.Third.Color}" />

    <LinearGradientBrush x:Key="Theme.Hero.Background.Brush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Offset="0" Color="{StaticResource Theme.Hero.Start.Color}" />
        <GradientStop Offset="1" Color="{StaticResource Theme.Hero.End.Color}" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="Theme.Hero.Glow.Brush" Color="{StaticResource Theme.Hero.Glow.Color}" />

    <Color x:Key="Main.Color">#5FD18D</Color>
    <SolidColorBrush x:Key="Main.Brush" Color="{StaticResource Main.Color}" />
    <Color x:Key="Main.Background.Color">#0F172A</Color>
    <SolidColorBrush x:Key="Main.Background.Brush" Color="{StaticResource Main.Background.Color}" />
    <Color x:Key="Main.Frontground.Color">#F8FAFC</Color>
    <SolidColorBrush x:Key="Main.Frontground.Brush" Color="{StaticResource Main.Frontground.Color}" />
    <Color x:Key="Main.Font.Color">#F8FAFC</Color>
    <SolidColorBrush x:Key="Main.Font.Brush" Color="{StaticResource Main.Font.Color}" />
    <Color x:Key="Brush.Color">#475467</Color>
    <SolidColorBrush x:Key="Brush.Brush" Color="{StaticResource Brush.Color}" />
    <SolidColorBrush x:Key="Third.Font.Brush" Color="{StaticResource Theme.Fill.2.Color}" />
</ResourceDictionary>

<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converter="clr-namespace:NaiveUI.NControls.Converters">
    <converter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <converter:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    <converter:SizeToCornerRadiusConverter x:Key="SizeToCornerRadiusConverter" />
    <converter:NormalAvatarConverter x:Key="NormalAvatarConverter" />
    <converter:AvatarBadgeToVisibilityConverter x:Key="AvatarBadgeToVisibilityConverter" />

    <CornerRadius x:Key="Radius.Small">8</CornerRadius>
    <CornerRadius x:Key="Radius.Medium">12</CornerRadius>
    <CornerRadius x:Key="Radius.Large">18</CornerRadius>
    <CornerRadius x:Key="Radius.XLarge">24</CornerRadius>
    <CornerRadius x:Key="Radius.Round">999</CornerRadius>

    <Thickness x:Key="Padding.Small">12,6</Thickness>
    <Thickness x:Key="Padding.Medium">16,10</Thickness>
    <Thickness x:Key="Padding.Large">20,12</Thickness>
</ResourceDictionary>
